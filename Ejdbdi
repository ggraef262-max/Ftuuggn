-- ====== جسيمات متحركة ======
local particles = {}
for i = 1, 20 do
    local particle = Instance.new("Frame", gui)
    particle.Size = UDim2.fromOffset(math.random(2, 8), math.random(2, 8))
    particle.Position = UDim2.fromScale(math.random(), math.random())
    particle.BackgroundColor3 = PRIMARY:lerp(SECONDARY, math.random())
    particle.BackgroundTransparency = 0.4
    particle.BorderSizePixel = 0
    particle.ZIndex = 1
    
    local corner = Instance.new("UICorner", particle)
    corner.CornerRadius = UDim.new(1, 0)
    
    table.insert(particles, {
        frame = particle,
        speed = Vector2.new(math.random(-50, 50)/1000, math.random(-30, 30)/1000),
        transparencySpeed = math.random(1, 5)/10
    })
end

