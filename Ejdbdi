-- ======================
-- حلقة التحميل الرئيسية
-- ======================
local startTime = tick()
local connection
local msgIndex = 1

connection = RunService.RenderStepped:Connect(function()
    local elapsed = tick() - startTime
    local progress = math.min(elapsed / 4, 1) -- تحميل أسرع
    
    -- تحديث الشريط
    ProgressFill.Size = UDim2.new(progress, 0, 1, 0)
    PercentText.Text = math.floor(progress * 100) .. "%"
    
    -- تحديث الرسالة كل 0.8 ثانية
    if math.floor(elapsed * 1.25) > math.floor((elapsed - 0.1) * 1.25) then
        msgIndex = (msgIndex % #titaniumMessages) + 1
        StatusText.Text = titaniumMessages[msgIndex]
    end
    
    -- تأثيرات عند نقاط معينة
    if progress > 0.33 and progress < 0.34 then
        for i = 1, 15 do
            createSnowflake()
        end
    elseif progress > 0.66 and progress < 0.67 then
        for i = 1, 15 do
            createSnowflake()
        end
    end
    
    -- الانتهاء من التحميل
    if progress >= 1 then
        connection:Disconnect()
        
        -- انفجار ثلجي
        for i = 1, 20 do
            createSnowflake()
            task.wait(0.02)
        end
        
        -- إخفاء شريط التحميل وإظهار خيارات اللغة
        ProgressContainer.Visible = false
        StatusFrame.Visible = false
        LanguageSelectionFrame.Visible = true
        
        StatusText.Text = "✅ SELECT LANGUAGE ✅"
        
        -- وظائف الأزرار
        local function executeScript(scriptUrl)
            -- انفجار ثلجي قبل التشغيل
            for i = 1, 30 do
                createSnowflake()
                task.wait(0.02)
            end
            
            LanguageSelectionFrame.Visible = false
            StatusFrame.Visible = true
            StatusText.Text = "🚀 DEPLOYING SCRIPT 🚀"
            task.wait(1)
            
            ScreenGui:Destroy()
            
            -- تشغيل السكربت
            local success, err = pcall(function()
                loadstring(game:HttpGet(scriptUrl))()
            end)
            
            if not success then
                warn("CLOCK7 TITANIUM ERROR: " .. tostring(err))
            end
        end
        
        ArabicButton.MouseButton1Click:Connect(function()
            executeScript(ARABIC_SCRIPT_URL)
        end)
        
        EnglishButton.MouseButton1Click:Connect(function()
            executeScript(ENGLISH_SCRIPT_URL)
        end)
    end
end)
