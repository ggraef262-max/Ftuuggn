local function LoadMainScript()
    print("بدء تحميل السكربت الرئيسي...")
    
    -- رابط السكربت الرئيسي (Clock7 RP)
    local scriptUrl = "https://raw.githubusercontent.com/ggraef262-max/Ftuuggn/refs/heads/main/%D8%A7%D9%84%D9%86%D8%B3%D8%AE%D9%87%20%D8%A7%D9%84%D8%A7%D8%AE%D9%8A%D8%B1%D9%87"
    
    -- تحميل وتشغيل السكربت
    local success, result = pcall(function()
        local scriptContent = game:HttpGet(scriptUrl)
        local func = loadstring(scriptContent)
        if func then
            func()
            print("تم تشغيل السكربت الرئيسي بنجاح!")
        else
            warn("فشل في تنفيذ السكربت")
        end
    end)
    
    if not success then
        warn("خطأ في تحميل السكربت: " .. tostring(result))
        -- عرض إشعار في حالة فشل التحميل
        game.StarterGui:SetCore("SendNotification", {
            Title = "CLOCK7",
            Text = "حدث خطأ في تحميل السكربت",
            Duration = 5
        })
    end
end

-- دالة تشغيل التحميل ثم إخفاء الشاشة
local function StartLoadingAndShowUI()
    local screenGui, progressBar, percentageLabel, statusLabel, mainFrame = CreateLoadingScreen()
    LoadingScreenGui = screenGui
    
    -- تشغيل تحديث الجسيمات
    local particleConnection = RunService.Heartbeat:Connect(function()
        UpdateParticles(mainFrame)
    end)
    table.insert(AnimationConnections, particleConnection)
    
    local startTime = tick()
    local currentElementIndex = 1
    local lastElementTime = startTime
    local elementDuration = LoadingConfig.Duration / #LoadingElements
    
    -- تحديث شريط التحميل
    local function updateLoading()
        local elapsed = tick() - startTime
        local progress = math.min(elapsed / LoadingConfig.Duration, 1)
        local percentage = math.floor(progress * 100)
        
        -- تحديث شريط التحميل
        local barTween = TweenService:Create(
            progressBar,
            TweenInfo.new(0.1, Enum.EasingStyle.Linear),
            {Size = UDim2.new(progress, 0, 1, 0)}
        )
        barTween:Play()
        
        percentageLabel.Text = percentage .. "%"
        
        -- تحديث النص
        if tick() - lastElementTime >= elementDuration and currentElementIndex <= #LoadingElements then
            statusLabel.Text = LoadingElements[currentElementIndex]
            currentElementIndex = currentElementIndex + 1
            lastElementTime = tick()
        end
        
        if progress >= 1 then
            -- إنهاء التحميل وإخفاء الشاشة
            for _, connection in pairs(AnimationConnections) do
                if typeof(connection) == "RBXScriptConnection" then
                    connection:Disconnect()
                elseif typeof(connection) == "Tween" then
                    connection:Cancel()
                end
            end
            
            -- إخفاء الجسيمات
            for _, particle in pairs(Particles) do
                if particle.frame then
                    particle.frame:Destroy()
                end
            end
            
            -- تأثير الاختفاء
            local fadeOutTween = TweenService:Create(
                mainFrame,
                TweenInfo.new(LoadingConfig.FadeOutTime, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
                {BackgroundTransparency = 1}
            )
            
            local contentFadeTween = TweenService:Create(
                mainFrame.CenterContainer,
                TweenInfo.new(LoadingConfig.FadeOutTime * 0.7, Enum.EasingStyle.Back, Enum.EasingDirection.In),
                {Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(0.5, 0, 0.5, 0)}
            )
            
            fadeOutTween:Play()
            contentFadeTween:Play()
            
            fadeOutTween.Completed:Connect(function()
                screenGui:Destroy()
                -- بعد إخفاء شاشة التحميل، يتم تشغيل الواجهة الرئيسية
                LoadMainScript()
            end)
            return
        end
        
        task.wait(0.03)
        updateLoading()
    end
    
    updateLoading()
end

