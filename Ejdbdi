percentLabel.Font = Enum.Font.GothamBold
percentLabel.TextSize = 30
percentLabel.TextColor3 = WHITE
percentLabel.ZIndex = 3

-- ====== تأثيرات حركية ======
RunService.RenderStepped:Connect(function(dt)
    local time = tick()
    
    -- حركة الجسيمات
    for _, p in ipairs(particles) do
        local pos = p.frame.Position
        local newX = pos.X.Scale + p.speed.X * dt * 60
        local newY = pos.Y.Scale + p.speed.Y * dt * 60
        
        if newX < 0 or newX > 1 then
            p.speed = Vector2.new(-p.speed.X, p.speed.Y)
            newX = math.clamp(newX, 0, 1)
        end
        if newY < 0 or newY > 1 then
            p.speed = Vector2.new(p.speed.X, -p.speed.Y)
            newY = math.clamp(newY, 0, 1)
        end
        
        p.frame.Position = UDim2.fromScale(newX, newY)
        p.frame.BackgroundTransparency = 0.3 + math.sin(time * p.transparencySpeed) * 0.2
    end
    
    -- دوران التدرج في الخلفية
    gradient.Rotation = gradient.Rotation + dt * 10
end)

