local SnowContainer = Instance.new("Folder")
SnowContainer.Parent = ScreenGui

local function createSnowflake()
    local snow = Instance.new("TextLabel")
    snow.Size = UDim2.new(0, math.random(5, 15), 0, math.random(5, 15))
    snow.Position = UDim2.new(math.random(), 0, 0, -math.random(10, 50))
    snow.BackgroundTransparency = 1
    snow.Text = "❄️"
    snow.TextColor3 = Color3.fromRGB(220, 240, 255)
    snow.TextScaled = true
    snow.Font = Enum.Font.SourceSansBold
    snow.Rotation = math.random(0, 360)
    snow.Parent = SnowContainer
    
    -- خصائص إضافية للثلج
    local transparency = math.random(0, 3) / 10
    snow.TextTransparency = transparency
    
    local duration = math.random(4, 10)
    local endX = snow.Position.X.Scale + (math.random(-10, 10) / 200)
    
    -- تمايل ناعم
    local tween = TweenService:Create(snow, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
        Position = UDim2.new(endX, 0, 1.2, 0),
        Rotation = snow.Rotation + math.random(-90, 90)
    })
    tween:Play()
    
    tween.Completed:Connect(function()
        snow:Destroy()
    end)
end

-- ثلج كثيف (20 ندفة في الثانية)
spawn(function()
