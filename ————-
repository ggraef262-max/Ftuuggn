-- ========== كود السحب البسيط والشغال ==========
local dragging = false
local dragStartX, dragStartY
local buttonStartX, buttonStartY

button.MouseButton1Down:Connect(function()
    dragging = true
    dragStartX = mouse.X
    dragStartY = mouse.Y
    buttonStartX = button.Position.X.Offset
    buttonStartY = button.Position.Y.Offset
end)

mouse.Move:Connect(function()
    if dragging then
        local deltaX = mouse.X - dragStartX
        local deltaY = mouse.Y - dragStartY
        
        button.Position = UDim2.new(
            button.Position.X.Scale,
            buttonStartX + deltaX,
            button.Position.Y.Scale,
            buttonStartY + deltaY
        )
    end
end)

button.MouseButton1Up:Connect(function()
    dragging = false
end)

-- منع تنفيذ التبديل عند السحب
local isActive = false
local clickTime = 0

button.MouseButton1Click:Connect(function()
    -- إذا كان السحب نشط، نمنع التبديل
    if dragging then
        return
    end
    
    isActive = not isActive
    
    if isActive then
        startSpamming()
        button.Text = "offإيقاف"
        button.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
    else
        stopSpamming()
        button.Text = "on تشغيل"
        button.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
    end
end)
