local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local mouse = LocalPlayer:GetMouse()

local running = false
local currentTask = nil

local function getCDs()
    return 
        workspace.__DEV.SwapablePOIs.PastryAndIceCream.PlotButtons.PastryShop.ClickDetector,
        workspace.__DEV.SwapablePOIs.PastryAndIceCream.PlotButtons.IceCreamShop.ClickDetector
end

local function startSpamming()
    if currentTask then return end
    running = true
    currentTask = task.spawn(function()
        while running do
            local p, i = getCDs()
            pcall(function() fireclickdetector(p) end)
            pcall(function() fireclickdetector(i) end)
            task.wait(0.05)
        end
        currentTask = nil
    end)
end

local function stopSpamming()
    running = false
end

