        )
        pulseTween:Play()
        table.insert(AnimationConnections, pulseTween)
        
        local rainbowCircle = RunService.Heartbeat:Connect(function()
            local hue = (tick() * 0.3 + (i * 0.1)) % 1
            circle.BackgroundColor3 = Color3.fromHSV(hue, 1, 1)
        end)
        table.insert(AnimationConnections, rainbowCircle)
