                                currentCouch.Parent = LocalPlayer.Character
                                wait()
                                
                                currentCouch.Parent = LocalPlayer.Backpack
                                if currentCouch.Handle then currentCouch.Handle.Name = "Handle " end
                                wait(0.2)
                                
                                currentCouch.Parent = LocalPlayer.Character
                                
                                bv = Instance.new("BodyVelocity", currentCouch:FindFirstChild("Seat1"))
                                bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                                bv.P = 1250
                                bv.Velocity = Vector3.new(0, 0, 0)
                                
                                local targetHum = target.Character:FindFirstChildOfClass("Humanoid")
                                if targetHum and targetHum.Sit then
                                    wait()
                                    local vel = currentCouch:FindFirstChild("Handle "):FindFirstChildOfClass("BodyVelocity")
                                    if vel then vel:Destroy() end
                                    
                                    currentCouch.Parent = LocalPlayer.Backpack
                                    wait()
                                    
                                    local h2 = currentCouch:FindFirstChild("Handle ")
                                    if h2 then h2.Name = "Handle" end
                                    wait(0.2)
                                    
                                    currentCouch.Parent = LocalPlayer.Character
                                    wait()
                                    
                                    currentCouch.Parent = LocalPlayer.Backpack
                                    break
                                end
                            end
                        end)()
                    end
                end
            end
        end
        
        sendNotification("قاذف", "تم تفعيل قاذف الكنبة للكل", nil, 2)
    end
})

