local function bringWithBus()
    if not selectedPlayer then
        sendNotification("خطأ", "لم يتم اختيار لاعب", nil, 3)
        return
    end
    
    local target = Players:FindFirstChild(selectedPlayer)
    if not target or not target.Character then
        sendNotification("خطأ", "اللاعب غير موجود", nil, 3)
        return
    end
    
    local root = getRootPart()
    if not root then return end
    
    local originalPos = root.CFrame
    
    -- الحصول على الباص
    local myCar = Workspace.Vehicles and Workspace.Vehicles:FindFirstChild(LocalPlayer.Name .. "Car")
    
    if not myCar then
        root.CFrame = CFrame.new(1118.81, 75.998, -1138.61)
        wait(0.5)
        fireRemote({"RE", "1Ca1r"}, "PickingCar", "SchoolBus")
        wait(1)
        myCar = Workspace.Vehicles and Workspace.Vehicles:FindFirstChild(LocalPlayer.Name .. "Car")
    end
    
    if not myCar then
        sendNotification("خطأ", "فشل في استدعاء الباص", nil, 3)
        return
    end
    
    -- الجلوس في الباص
    local seat = myCar:FindFirstChild("Body") and myCar.Body:FindFirstChild("VehicleSeat")
