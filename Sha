                if humanoid then
                    humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, false)
                    local conn = humanoid.StateChanged:Connect(function(_, state)
                        if state == Enum.HumanoidStateType.Seated then
                            humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
                        end
                    end)
                    table.insert(antiSitConnections, conn)
                end
            end
            
            -- للشخصية الحالية
            local humanoid = getHumanoid()
            if humanoid then
                applyAntiSit(humanoid)
            end
            
            -- للشخصيات الجديدة
            local charConn = LocalPlayer.CharacterAdded:Connect(function(char)
                wait(0.5)
                local newHumanoid = char:FindFirstChildOfClass("Humanoid")
                if newHumanoid then
                    applyAntiSit(newHumanoid)
                end
            end)
            table.insert(antiSitConnections, charConn)
            
            -- حلقة مستمرة للتأكيد
            local loopConn = RunService.Heartbeat:Connect(function()
                local hum = getHumanoid()
