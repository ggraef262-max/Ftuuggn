local blackholeRadius = 10
local blackholeConnection = nil
local blackholeAttachment = nil
local blackholeParts = {}

local function createBlackholeAttachment()
    if blackholeAttachment then return end
    
    local root = getRootPart()
    if not root then return end
    
    local part = Instance.new("Part")
    part.Size = Vector3.new(1, 1, 1)
    part.Transparency = 1
    part.Anchored = true
    part.CanCollide = false
    part.Parent = Workspace
    
    local attachment = Instance.new("Attachment")
    attachment.Parent = part
    blackholeAttachment = attachment
    
    RunService.Heartbeat:Connect(function()
        local currentRoot = getRootPart()
        if currentRoot then
            part.CFrame = currentRoot.CFrame
        end
    end)
    
    return attachment
end

local function applyBlackholeToPart(part)
    if not part:IsA("BasePart") or part.Anchored or part:FindFirstChild("_BLACKHOLE_ATTACHED") then
        return
    end
    
    local root = getRootPart()
    if not root then return end
    
    -- تنظيف المكونات القديمة
    for _, child in ipairs(part:GetChildren()) do
        if child:IsA("BodyMover") or child:IsA("AlignPosition") or child:IsA("Torque") then
            child:Destroy()
        end
    end
    
    -- إضافة علامة
    local marker = Instance.new("BoolValue")
    marker.Name = "_BLACKHOLE_ATTACHED"
    marker.Parent = part
    
    -- إضافة المكونات الجديدة
    local partAttach = Instance.new("Attachment", part)
    
    local align = Instance.new("AlignPosition", part)
    align.Attachment0 = partAttach
    align.Attachment1 = blackholeAttachment
    align.MaxForce = math.huge
    align.MaxVelocity = math.huge
    align.Responsiveness = 200
    
    local torque = Instance.new("Torque", part)
    torque.Attachment0 = partAttach
    torque.Torque = Vector3.new(100000, 100000, 100000)
    
    table.insert(blackholeParts, part)
end

bringTab:AddButton({
    Name = "تفعيل الثقب الأسود",
    Description = "يجذب جميع القطع القريبة منك",
    Callback = function()
        if blackholeActive then
            blackholeActive = false
            if blackholeConnection then
                blackholeConnection:Disconnect()
                blackholeConnection = nil
            end
            blackholeAttachment = nil
            blackholeParts = {}
            sendNotification("الثقب الأسود", "تم إيقاف الثقب الأسود", nil, 2)
            return
        end
        
        blackholeActive = true
        createBlackholeAttachment()
        
        -- جذب القطع الموجودة
        for _, descendant in ipairs(Workspace:GetDescendants()) do
            if descendant:IsA("BasePart") and not descendant.Anchored and not descendant.Parent:FindFirstChildOfClass("Humanoid") then
                applyBlackholeToPart(descendant)
            end
        end
        
        -- مراقبة القطع الجديدة
        blackholeConnection = Workspace.DescendantAdded:Connect(function(descendant)
            if blackholeActive and descendant:IsA("BasePart") and not descendant.Anchored and not descendant.Parent:FindFirstChildOfClass("Humanoid") then
                applyBlackholeToPart(descendant)
            end
        end)
        
        sendNotification("الثقب الأسود", "تم تفعيل الثقب الأسود", nil, 2)
    end
})

