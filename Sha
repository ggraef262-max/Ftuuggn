local function bringWithCouch(noTarget)
    if not selectedPlayer then
        sendNotification("خطأ", "لم يتم اختيار لاعب", nil, 3)
        return
    end
    
    local target = Players:FindFirstChild(selectedPlayer)
    if not target or not target.Character then
        sendNotification("خطأ", "اللاعب غير موجود", nil, 3)
        return
    end
    
    -- تنظيف الأدوات
    fireRemote({"RE", "1Clea1rTool1s"}, "ClearAllTools")
    wait(0.2)
    
    -- الحصول على الكنبة
    invokeRemote({"RE", "1Too1l"}, "PickingTools", "Couch")
    wait(0.3)
    
    local couch = LocalPlayer.Backpack:FindFirstChild("Couch")
    if not couch then
        sendNotification("خطأ", "لم يتم العثور على الكنبة", nil, 3)
        return
    end
    
    couch.Name = "Chaos.Couch"
    local seat1 = couch:FindFirstChild("Seat1")
    local seat2 = couch:FindFirstChild("Seat2")
    local handle = couch:FindFirstChild("Handle")
    
    if not (seat1 and seat2 and handle) then
        sendNotification("خطأ", "أجزاء الكنبة غير مكتملة", nil, 3)
        return
    end
    
    seat1.Disabled = true
    seat2.Disabled = true
    handle.Name = "Handle "
    
    couch.Parent = LocalPlayer.Character
    
    local bv = Instance.new("BodyVelocity", seat1)
    bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bv.P = 1250
    bv.Velocity = Vector3.new(0, 0, 0)
    bv.Name = "BRING_VELOCITY"
    
    coroutine.wrap(function()
        while target and target.Character do
            for i = 1, 35 do
                local targetRoot = target.Character:FindFirstChild("HumanoidRootPart")
                if not targetRoot then break end
                
                local pos = targetRoot.Position + targetRoot.Velocity / 2
                seat1.CFrame = CFrame.new(pos) * CFrame.new(-2, 2, 0)
                task.wait()
            end
            
            -- إعادة تعيين الكنبة
            bv:Destroy()
            couch.Parent = LocalPlayer.Backpack
            task.wait()
            
            local h = couch:FindFirstChild("Handle ")
            if h then h.Name = "Handle" end
            task.wait(0.2)
            
            couch.Parent = LocalPlayer.Character
            task.wait()
            
            couch.Parent = LocalPlayer.Backpack
            if couch.Handle then couch.Handle.Name = "Handle " end
            task.wait(0.2)
            
            couch.Parent = LocalPlayer.Character
            
            bv = Instance.new("BodyVelocity", seat1)
            bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            bv.P = 1250
            bv.Velocity = Vector3.new(0, 0, 0)
            bv.Name = "BRING_VELOCITY"
            
            if noTarget then
                local targetHum = target.Character:FindFirstChildOfClass("Humanoid")
                if targetHum and targetHum.Sit then
                    wait()
                    couch.Parent = LocalPlayer.Backpack
                    wait()
                    if couch:FindFirstChild("Handle ") then
                        couch:FindFirstChild("Handle ").Name = "Handle"
                    end
                    wait(0.3)
                    couch.Parent = LocalPlayer.Character
                    wait(0.3)
                    couch.Grip = CFrame.new(Vector3.new(0, 0, 0))
                    wait(0.3)
                    fireRemote({"RE", "1Clea1rTool1s"}, "ClearAllTools")
                    sendNotification("جلب", "تم جلب " .. target.Name, nil, 2)
                    break
                end
            end
        end
    end)()
    
    sendNotification("جلب", "جاري جلب " .. target.Name .. " بالكنبة", nil, 2)
end

