-- ==================== دوال مساعدة ====================
local function GetStr(val)
    if type(val) == "function" then return val() end
    return val
end

local function CreateTween(instance, prop, value, time, wait)
    local tween = TweenService:Create(instance, TweenInfo.new(time or 0.3, Enum.EasingStyle.Quint), {[prop] = value})
    tween:Play()
    if wait then tween.Completed:Wait() end
    return tween
end

local function Create(instanceType, parent, props)
    local new = Instance.new(instanceType)
    if parent then new.Parent = parent end
    if props then
        for prop, value in pairs(props) do
            new[prop] = value
        end
    end
    return new
end

local function InsertTheme(instance, typeName)
    table.insert(Instances, {Instance = instance, Type = typeName})
    return instance
end

