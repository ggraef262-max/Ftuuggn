                Position = UDim2.new(1, -12, 0.5, 0),
                AnchorPoint = Vector2.new(1, 0.5),
                Text = defaultKey,
                BackgroundColor3 = Color3.fromRGB(50, 50, 50),
                TextColor3 = CurrentTheme["Color Text"],
                Font = Enum.Font.GothamBold,
                TextSize = 11
            })
            Create("UICorner", keyButton, {CornerRadius = UDim.new(0, 6)})
            
            local listening = false
            local currentKey = defaultKey
            
            keyButton.MouseButton1Click:Connect(function()
                listening = true
                keyButton.Text = "..."
                
                local connection
                connection = UserInputService.InputBegan:Connect(function(input)
                    if listening then
                        local key = input.KeyCode.Name
                        if key ~= "Unknown" then
                            currentKey = key
                            keyButton.Text = key
                            pcall(callback, key)
                            listening = false
                            connection:Disconnect()
                        end
                    end
                end)
                
                task.wait(3)
                if listening then
                    listening = false
                    keyButton.Text = currentKey
                    connection:Disconnect()
                end
            end)
            
            local element = {Frame = frame}
            table.insert(elements, element)
            
            function element:SetKey(newKey)
                currentKey = newKey
                keyButton.Text = newKey
            end
            
            function element:Destroy()
                frame:Destroy()
            end
            
            return element
        end
        
        function tabMethods:AddTimer(config)
            local timerName = config.Title or "Timer"
            local defaultTime = config.Default or 10
            local callback = config.Callback or function() end
            
            local frame = Create("Frame", container, {
                Size = UDim2.new(1, 0, 0, 70),
                BackgroundColor3 = CurrentTheme["Color Hub 2"]
            })
            InsertTheme(frame, "Frame")
            Create("UICorner", frame, {CornerRadius = UDim.new(0, 8)})
            
            local label = InsertTheme(Create("TextLabel", frame, {
                Size = UDim2.new(1, -12, 0, 20),
                Position = UDim2.new(0, 12, 0, 8),
                Text = timerName,
                TextColor3 = CurrentTheme["Color Text"],
                Font = Enum.Font.GothamMedium,
                TextSize = 12,
                TextXAlignment = "Left",
                BackgroundTransparency = 1
            }), "Text")
            
            local timeLabel = InsertTheme(Create("TextLabel", frame, {
                Size = UDim2.new(0, 80, 0, 30),
                Position = UDim2.new(0.5, -40, 0, 35),
                Text = tostring(defaultTime),
                TextColor3 = CurrentTheme["Color Theme"],
                Font = Enum.Font.FredokaOne,
                TextSize = 24,
                BackgroundTransparency = 1
            }), "Theme")
            
            local startBtn = Create("TextButton", frame, {
                Size = UDim2.new(0, 70, 0, 28),
                Position = UDim2.new(0.5, -75, 1, -10),
                Text = "▶ بدء",
                BackgroundColor3 = CurrentTheme["Color Theme"],
                TextColor3 = CurrentTheme["Color Text"],
                Font = Enum.Font.GothamBold,
                TextSize = 11
            })
            Create("UICorner", startBtn, {CornerRadius = UDim.new(0, 6)})
            
            local resetBtn = Create("TextButton", frame, {
                Size = UDim2.new(0, 70, 0, 28),
                Position = UDim2.new(0.5, 5, 1, -10),
                Text = "↺ إعادة",
                BackgroundColor3 = Color3.fromRGB(80, 80, 80),
                TextColor3 = CurrentTheme["Color Text"],
                Font = Enum.Font.GothamBold,
                TextSize = 11
            })
            Create("UICorner", resetBtn, {CornerRadius = UDim.new(0, 6)})
            
            local remaining = defaultTime
            local running = false
            local connection
            
            local function updateDisplay()
                timeLabel.Text = tostring(math.floor(remaining))
                if remaining <= 0 and running then
                    running = false
                    if connection then connection:Disconnect() end
                    startBtn.Text = "▶ بدء"
                    startBtn.BackgroundColor3 = CurrentTheme["Color Theme"]
                    pcall(callback)
                end
            end
            
            startBtn.MouseButton1Click:Connect(function()
                running = not running
                if running then
                    startBtn.Text = "⏸ إيقاف"
                    startBtn.BackgroundColor3 = Color3.fromRGB(200, 80, 80)
                    connection = RunService.Heartbeat:Connect(function(dt)
                        if running and remaining > 0 then
                            remaining = remaining - dt
                            updateDisplay()
                        end
                    end)
                else
                    startBtn.Text = "▶ بدء"
                    startBtn.BackgroundColor3 = CurrentTheme["Color Theme"]
                    if connection then connection:Disconnect() end
                end
            end)
            
            resetBtn.MouseButton1Click:Connect(function()
                remaining = defaultTime
                updateDisplay()
                if running then
                    running = false
                    startBtn.Text = "▶ بدء"
                    startBtn.BackgroundColor3 = CurrentTheme["Color Theme"]
                    if connection then connection:Disconnect() end
                end
            end)
            
            local element = {Frame = frame}
            table.insert(elements, element)
            
            function element:SetTime(newTime)
                defaultTime = newTime
                remaining = newTime
                updateDisplay()
            end
            
            function element:Destroy()
                if connection then connection:Disconnect() end
                frame:Destroy()
            end
            
            return element
        end
        
        function tabMethods:AddDiscord(config)
            local invite = config.Invite or "https://discord.gg/"
            local title = config.Title or "Discord Server"
            local description = config.Description or "انضم للسيرفر للحصول على التحديثات"
            local icon = config.Icon or "rbxassetid://10709752035"
            
            local frame = Create("Frame", container, {
                Size = UDim2.new(1, 0, 0, 90),
                BackgroundColor3 = CurrentTheme["Color Hub 2"]
            })
            InsertTheme(frame, "Frame")
            Create("UICorner", frame, {CornerRadius = UDim.new(0, 12)})
            
            local iconImg = Create("ImageLabel", frame, {
                Size = UDim2.new(0, 50, 0, 50),
                Position = UDim2.new(0, 12, 0, 12),
                Image = icon,
                BackgroundTransparency = 1,
                ImageColor3 = CurrentTheme["Color Theme"]
            })
            
            local titleLabel = InsertTheme(Create("TextLabel", frame, {
                Size = UDim2.new(1, -80, 0, 20),
                Position = UDim2.new(0, 70, 0, 12),
                Text = title,
                TextColor3 = CurrentTheme["Color Text"],
                Font = Enum.Font.GothamBold,
                TextSize = 14,
                TextXAlignment = "Left",
                BackgroundTransparency = 1
            }), "Text")
            
            local descLabel = InsertTheme(Create("TextLabel", frame, {
                Size = UDim2.new(1, -80, 0, 30),
                Position = UDim2.new(0, 70, 0, 34),
                Text = description,
                TextColor3 = CurrentTheme["Color Dark Text"],
                Font = Enum.Font.Gotham,
                TextSize = 10,
                TextXAlignment = "Left",
                TextWrapped = true,
                BackgroundTransparency = 1
            }), "DarkText")
            
            local joinBtn = Create("TextButton", frame, {
                Size = UDim2.new(0, 100, 0, 30),
                Position = UDim2.new(1, -12, 0.5, 0),
                AnchorPoint = Vector2.new(1, 0.5),
                Text = "انضم",
                BackgroundColor3 = CurrentTheme["Color Theme"],
                TextColor3 = CurrentTheme["Color Text"],
                Font = Enum.Font.GothamBold,
                TextSize = 12
            })
            Create("UICorner", joinBtn, {CornerRadius = UDim.new(0, 6)})
            
            joinBtn.MouseButton1Click:Connect(function()
                setclipboard(invite)
                LegendaryUI:Notify({Title = "Discord", Text = "تم نسخ الرابط!", Duration = 2})
                joinBtn.Text = "تم النسخ!"
                joinBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
                task.wait(2)
                joinBtn.Text = "انضم"
                joinBtn.BackgroundColor3 = CurrentTheme["Color Theme"]
            end)
            
            local element = {Frame = frame}
            table.insert(elements, element)
            
            function element:Destroy()
                frame:Destroy()
            end
            
            return element
        end
        
        function tabMethods:Clear()
            for _, child in pairs(container:GetChildren()) do
                if child:IsA("Frame") and child ~= container then
                    child:Destroy()
                end
            end
        end
        
        function tabMethods:Destroy()
            tabButton:Destroy()
            container:Destroy()
        end
        
        return tabMethods
    end
    
    closeBtn.MouseButton1Click:Connect(function()
        windowMethods:Dialog({
            Title = "إغلاق",
            Text = "هل أنت متأكد من إغلاق السكربت؟",
            Buttons = {
                {"نعم", function() windowMethods:Close() end},
                {"لا", function() end}
            }
        })
    end)
    
    return windowMethods
end

