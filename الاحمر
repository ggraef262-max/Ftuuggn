end

--[====[
    دالة مساعدة أساسية: تقوم بإنشاء حلقة (Loop) تعمل بشكل متكرر.
    هذه الدالة هي القلب النابض لجميع مضادات الـ Fling.
    الوظيفة: تبحث باستمرار عن عناصر معينة (مثل الزوارق، الطائرات) في مجلداتها.
    إذا وجدت عنصرًا لا يخص اللاعب (أي عنصر يمكن استخدامه لتنفيذ Fling ضدك)،
    تقوم بحذفه لمنع الخطر، ولكن قبل الحذف، تحفظ نسخة منه في `backupTables`.
    - name: اسم نوع العنصر (للتخزين في الجدول الاحتياطي).
    - getFolderFunc: دالة ترجع المجلد الذي توجد فيه هذه العناصر.
]====]
local function AntiFlingLoop(name, getFolderFunc)
    local active = false
    task.spawn(function()
        while true do
            if active and LocalPlayer.Character then
                local folder = getFolderFunc()
                if folder then
                    for _, item in ipairs(folder:GetChildren()) do
                        local isMine = false
                        -- التحقق مما إذا كان العنصر يخص اللاعب المحلي
                        if name == "Vehicles" then
                            -- للسيارات: نتحقق إذا كان أي كرسي في السيارة يجلس عليه اللاعب
                            for _, seat in ipairs(item:GetDescendants()) do
                                if (seat:IsA("VehicleSeat") or seat:IsA("Seat")) and seat.Occupant and seat.Occupant.Parent == LocalPlayer.Character then
                                    isMine = true
                                    break
                                end
                            end
                        elseif name == "Canoes" then
                            -- للزوارق: نتحقق من وجود متغير (Value) اسمه Owner وقيمته تساوي اللاعب
                            local owner = item:FindFirstChild("Owner")
                            isMine = owner and owner.Value == LocalPlayer
                        elseif name == "Jets" or name == "Helis" then
                            -- للطائرات: اسم العنصر نفسه هو اسم اللاعب (عادةً)
                            isMine = item.Name == LocalPlayer.Name
                        end
                        
                        -- إذا كان العنصر لا يخصنا، نقوم بحذفه بعد حفظ نسخة منه
                        if not isMine then
                            table.insert(backupTables[name], item:Clone())
                            item:Destroy()
                        end
                    end
                end
            end
            task.wait(0.03) -- ننتظر 0.03 ثانية قبل تكرار الحلقة (سرعة عالية)
        end
    end)
    -- هذه الدالة ترجع دالة أخرى يتم استدعائها عند تشغيل/إيقاف التبديل (Toggle)
    return function(state)
        active = state
        TeleportCarro:MostrarNotificacao(name.." "..(state and "مُفعل!" or "مُعطل!"))
        if not state then
            -- عند إيقاف التشغيل، نقوم باستعادة جميع العناصر التي حذفناها سابقًا
            for _, item in ipairs(backupTables[name]) do
                local parentFolder = getFolderFunc()
                if parentFolder then 
                    item.Parent = parentFolder 
                end
            end
            backupTables[name] = {} -- تفريغ الجدول الاحتياطي بعد الاستعادة
        end
    end
end

