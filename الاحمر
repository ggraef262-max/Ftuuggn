--[====[
    جدول لحفظ نسخ احتياطية من العناصر (المركبات، الزوارق، الطائرات، الكرات).
    الفكرة: قبل حذف أي عنصر لا يخصنا، نقوم بحفظ نسخة منه، حتى نتمكن من استعادته
    لاحقًا عند إيقاف خاصية الحماية.
    هذا يمنع فقدان العناصر الأخرى في السيرفر نهائيًا.
]====]
local backupTables = {
    Vehicles = {},   -- للسيارات
    Canoes = {},     -- للزوارق (القوارب العادية)
    Jets = {},       -- للطائرات النفاثة
