-- ==================== دوال مساعدة ====================
local function CreateTween(instance, prop, value, time)
    local tween = TweenService:Create(instance, TweenInfo.new(time or 0.2, Enum.EasingStyle.Quad), {[prop] = value})
    tween:Play()
    return tween
end

local function Create(instanceType, parent, props)
    local new = Instance.new(instanceType)
    if parent then new.Parent = parent end
    if props then
        for prop, value in pairs(props) do
            new[prop] = value
        end
    end
    return new
end

local function InsertTheme(instance, typeName)
    table.insert(Instances, {Instance = instance, Type = typeName})
    return instance
end

-- ==================== دوال الثيم ====================
function LegendaryUI:ApplyTheme(themeName)
    if not Themes[themeName] then return end
    CurrentTheme = Themes[themeName]
    SaveData.Theme = themeName
    
    for _, item in pairs(Instances) do
        if item.Instance and item.Instance.Parent then
            if item.Type == "Gradient" then
                item.Instance.Color = CurrentTheme["Color Hub 1"]
            elseif item.Type == "FrameBG" then
                item.Instance.BackgroundColor3 = CurrentTheme["Color Hub 2"]
            elseif item.Type == "Stroke" then
                item.Instance.Color = CurrentTheme["Color Stroke"]
            elseif item.Type == "ThemeColor" then
                if item.Instance:IsA("Frame") then
                    item.Instance.BackgroundColor3 = CurrentTheme["Color Theme"]
                elseif item.Instance:IsA("TextLabel") or item.Instance:IsA("TextButton") then
                    item.Instance.TextColor3 = CurrentTheme["Color Theme"]
                elseif item.Instance:IsA("ImageLabel") then
                    item.Instance.ImageColor3 = CurrentTheme["Color Theme"]
                end
            elseif item.Type == "Text" then
                item.Instance.TextColor3 = CurrentTheme["Color Text"]
            elseif item.Type == "DarkText" then
                item.Instance.TextColor3 = CurrentTheme["Color Dark Text"]
            end
        end
    end
    
    LegendaryUI:Notify({Title = "🎨 ثيم", Text = "تم تغيير الثيم إلى " .. themeName, Duration = 2})
end

