                })
                Create("UICorner", hueBar, {CornerRadius = UDim.new(0, 6)})
                Create("UIGradient", hueBar, {
                    Rotation = 90,
                    Color = ColorSequence.new({
                        ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
                        ColorSequenceKeypoint.new(0.16, Color3.fromRGB(255, 255, 0)),
                        ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0, 255, 0)),
                        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 255, 255)),
                        ColorSequenceKeypoint.new(0.66, Color3.fromRGB(0, 0, 255)),
                        ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255, 0, 255)),
                        ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0))
                    })
                })
                
                local hueSlider = Create("TextButton", hueBar, {
                    Size = UDim2.new(0, 12, 1, 0), Position = UDim2.new(0, 0, 0, 0),
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255), Text = ""
                })
                Create("UICorner", hueSlider, {CornerRadius = UDim.new(1, 0)})
                
                local preview = Create("Frame", picker, {
                    Size = UDim2.new(0, 48, 0, 48), Position = UDim2.new(1, -12, 1, -12),
                    AnchorPoint = Vector2.new(1, 1), BackgroundColor3 = default
                })
                Create("UICorner", preview, {CornerRadius = UDim.new(0, 8)})
                Create("UIStroke", preview, {Color = theme.Border, Thickness = 1})
                
                local h, s, v = Color3.toHSV(default)
                hueSlider.Position = UDim2.new(h, -6, 0, 0)
                
                local function updateColor()
                    local newColor = Color3.fromHSV(h, s, v)
                    colorBtn.BackgroundColor3 = newColor
                    preview.BackgroundColor3 = newColor
                    if flag then SaveData.Flags[flag] = newColor; SaveSettings() end
                    pcall(cb, newColor)
                end
                
                hueSlider.MouseButton1Down:Connect(function()
                    local conn
                    conn = UserInputService.InputChanged:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseMovement then
                            local mousePos = UserInputService:GetMouseLocation()
                            local barPos = hueBar.AbsolutePosition.X
                            local barWidth = hueBar.AbsoluteSize.X
                            local percent = math.clamp((mousePos.X - barPos) / barWidth, 0, 1)
                            hueSlider.Position = UDim2.new(percent, -6, 0, 0)
                            h = percent
                            updateColor()
                        end
                    end)
                    UserInputService.InputEnded:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 then
                            conn:Disconnect()
                        end
                    end)
                end)
                
                picker.Size = UDim2.new(1, -24, 0, 110)
                frame.Size = UDim2.new(1, 0, 0, (desc and 68 or 52) + 110)
                open = true
            end)
            
            return {Destroy = function() frame:Destroy() end, SetColor = function(c) colorBtn.BackgroundColor3 = c; if flag then SaveData.Flags[flag] = c; SaveSettings() end; pcall(cb, c) end}
        end
        
        function tabMethods:Clear()
            for _, child in pairs(container:GetChildren()) do
                if child:IsA("Frame") then child:Destroy() end
            end
        end
        
        function tabMethods:Destroy()
            tabBtn:Destroy()
            container:Destroy()
        end
        
        return tabMethods
    end
    
    closeBtn.MouseButton1Click:Connect(function()
        methods:Dialog({
            Title = "إغلاق",
            Text = "هل أنت متأكد من إغلاق السكربت؟",
            Buttons = {
                {"نعم", function() methods:Close() end},
                {"لا", function() end}
            }
        })
    end)
    
    methods:Notify({Title = "Legendary UI", Text = "تم تحميل السكربت بنجاح!", Duration = 3})
    
    return methods
end

return LegendaryUI
