-- ==================== دوال مساعدة متقدمة ====================
local function GetStr(val)
    if type(val) == "function" then return val() end
    return val
end

local function CreateTween(instance, prop, value, time, style, wait)
    local easingStyle = style or Enum.EasingStyle.Quad
    local tweenInfo = TweenInfo.new(time or SaveData.AnimationSpeed, easingStyle, Enum.EasingDirection.Out)
    local tween = TweenService:Create(instance, tweenInfo, {[prop] = value})
    tween:Play()
    if wait then tween.Completed:Wait() end
    return tween
end

local function CreateEasingTween(instance, prop, value, time, easing, wait)
    local tweenInfo = TweenInfo.new(time or 0.4, easing or Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
    local tween = TweenService:Create(instance, tweenInfo, {[prop] = value})
    tween:Play()
    if wait then tween.Completed:Wait() end
    return tween
end

local function Create(instanceType, parent, props)
    local new = Instance.new(instanceType)
    if parent then new.Parent = parent end
    if props then
        for prop, value in pairs(props) do
            new[prop] = value
        end
    end
    return new
end

local function InsertTheme(instance, typeName)
    table.insert(Instances, {Instance = instance, Type = typeName})
    return instance
end

-- تأثير توهج متحرك للحدود
local function AddGlowEffect(frame, color)
    if not SaveData.GlowEffect then return end
    
    local glowColor = color or CurrentTheme["Color Glow"]
    local stroke = frame:FindFirstChildWhichIsA("UIStroke")
    
    if stroke then
        local glowAnim = RunService.RenderStepped:Connect(function()
            if stroke and stroke.Parent then
                local intensity = (math.sin(tick() * 5) + 1) / 2
                stroke.Transparency = 0.3 - (intensity * 0.2)
                if stroke.Color then
                    stroke.Color = glowColor
                end
            else
                glowAnim:Disconnect()
            end
        end)
        table.insert(GlowFrames, {Frame = frame, Animation = glowAnim})
    end
end

-- تأثير رائع عند hover
local function AddHoverEffect(button, color)
    local originalColor = button.BackgroundColor3
    local hoverColor = color or CurrentTheme["Color Theme"]
    
    button.MouseEnter:Connect(function()
        CreateTween(button, "BackgroundColor3", hoverColor, 0.15, Enum.EasingStyle.Quad, false)
        CreateTween(button, "BackgroundTransparency", 0.2, 0.15, Enum.EasingStyle.Quad, false)
        CreateTween(button, "Size", UDim2.new(1, 2, 1, 2), 0.1, Enum.EasingStyle.Quad, false)
    end)
    
    button.MouseLeave:Connect(function()
        CreateTween(button, "BackgroundColor3", originalColor, 0.2, Enum.EasingStyle.Quad, false)
        CreateTween(button, "BackgroundTransparency", 0, 0.2, Enum.EasingStyle.Quad, false)
        CreateTween(button, "Size", UDim2.new(1, 0, 1, 0), 0.1, Enum.EasingStyle.Quad, false)
    end)
end

