-- ==================================================== تأثيرات ====================================================
local function AddHoverEffect(button, color)
    local original = button.BackgroundColor3
    button.MouseEnter:Connect(function()
        Tween(button, "BackgroundColor3", color or GetTheme().Accent, 0.15)
        Tween(button, "Size", UDim2.new(button.Size.X.Scale, button.Size.X.Offset + 2, button.Size.Y.Scale, button.Size.Y.Offset + 2), 0.1)
    end)
    button.MouseLeave:Connect(function()
        Tween(button, "BackgroundColor3", original, 0.2)
        Tween(button, "Size", UDim2.new(button.Size.X.Scale, button.Size.X.Offset - 2, button.Size.Y.Scale, button.Size.Y.Offset - 2), 0.1)
    end)
end

local function AddRipple(button)
    button.MouseButton1Click:Connect(function()
        local ripple = Create("Frame", button, {
            Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(0.5, 0, 0.5, 0),
            AnchorPoint = Vector2.new(0.5, 0.5), BackgroundColor3 = Color3.fromRGB(255, 255, 255),
            BackgroundTransparency = 0.7, ZIndex = 10
        })
        Create("UICorner", ripple, {CornerRadius = UDim.new(1, 0)})
        Tween(ripple, "Size", UDim2.new(0, 120, 0, 120), 0.3)
        Tween(ripple, "BackgroundTransparency", 1, 0.3)
        task.wait(0.3)
        ripple:Destroy()
    end)
end

