        -- Slider with Percentage
        function tabMethods:AddPercentSlider(config)
            local sliderName = config.Title or "Percentage"
            local sliderDesc = config.Description or ""
            local default = config.Default or 50
            local flag = config.Flag
            local callback = config.Callback or function() end
            
            if flag and SaveData.Flags[flag] ~= nil then
                default = SaveData.Flags[flag]
            end
            
            local frame, titleLabel, descLabel = createBaseFrame(sliderName, sliderDesc, true)
            local theme = GetTheme()
            
            local percentLabel = Create("TextLabel", frame, {
                Size = UDim2.new(0, 60, 0, 28),
                Position = UDim2.new(1, -16, 0, 12),
                AnchorPoint = Vector2.new(1, 0),
                Text = tostring(default) .. "%",
                TextColor3 = theme.Primary,
                Font = Enum.Font.GothamBold,
                TextSize = 14,
                BackgroundTransparency = 1
            })
            
            local sliderBar = Create("Frame", frame, {
                Size = UDim2.new(1, -140, 0, 8),
                Position = UDim2.new(0, 16, 0, descLabel and 54 or 42),
                BackgroundColor3 = Color3.fromRGB(50, 50, 50)
            })
            Create("UICorner", sliderBar, {CornerRadius = UDim.new(1, 0)})
            
            local fill = Create("Frame", sliderBar, {
                Size = UDim2.new(default / 100, 0, 1, 0),
                BackgroundColor3 = theme.Primary
            })
            Create("UICorner", fill, {CornerRadius = UDim.new(1, 0)})
            
            local sliderButton = Create("TextButton", sliderBar, {
                Size = UDim2.new(0, 18, 0, 18),
                Position = UDim2.new(default / 100, -9, 0.5, 0),
                AnchorPoint = Vector2.new(0, 0.5),
                BackgroundColor3 = theme.Primary,
                Text = ""
            })
            Create("UICorner", sliderButton, {CornerRadius = UDim.new(1, 0)})
            
            local value = default
            
            local function updateSlider(newValue)
                value = Clamp(newValue, 0, 100)
                if flag then SaveData.Flags[flag] = value end
                pcall(callback, value)
                SaveSettings()
                percentLabel.Text = tostring(value) .. "%"
                local percent = value / 100
                fill.Size = UDim2.new(percent, 0, 1, 0)
                sliderButton.Position = UDim2.new(percent, -9, 0.5, 0)
            end
            
            sliderButton.MouseButton1Down:Connect(function()
                local connection
                connection = UserInputService.InputChanged:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseMovement then
                        local mousePos = UserInputService:GetMouseLocation()
                        local barPos = sliderBar.AbsolutePosition.X
                        local barWidth = sliderBar.AbsoluteSize.X
                        local newPercent = Clamp((mousePos.X - barPos) / barWidth, 0, 1)
                        updateSlider(newPercent * 100)
                    end
                end)
                
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        connection:Disconnect()
                    end
                end)
            end)
            
            local element = {Frame = frame, UpdateTheme = function(newTheme)
                frame.BackgroundColor3 = newTheme.Surface
                titleLabel.TextColor3 = newTheme.Text
                if descLabel then descLabel.TextColor3 = newTheme.TextDim end
                percentLabel.TextColor3 = newTheme.Primary
                fill.BackgroundColor3 = newTheme.Primary
                sliderButton.BackgroundColor3 = newTheme.Primary
            end}
            table.insert(elements, element)
            table.insert(LegendaryUI.Instances, element)
            
            function element:Set(newValue)
                updateSlider(newValue)
            end
            
            function element:Get()
                return value
            end
            
            function element:Destroy()
                frame:Destroy()
            end
            
            return element
        end
        
        function tabMethods:Clear()
            for _, child in pairs(container:GetChildren()) do
                if child:IsA("Frame") and child ~= container then
                    child:Destroy()
                end
            end
            elements = {}
        end
        
        function tabMethods:Destroy()
            tabButton:Destroy()
            container:Destroy()
            for i, elem in ipairs(elements) do
                for j, inst in ipairs(LegendaryUI.Instances) do
                    if inst == elem then
                        table.remove(LegendaryUI.Instances, j)
                        break
                    end
                end
            end
        end
        
        return tabMethods
    end
    
