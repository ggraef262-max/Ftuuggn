-- ==================== دوال إضافية ====================
function LegendaryUI:GetFlag(name)
    return Flags[name]
end

function LegendaryUI:SetFlag(name, value)
    Flags[name] = value
    SaveSettings()
end

function LegendaryUI:Unload()
    for _, glow in pairs(GlowFrames) do
        if glow.Animation then glow.Animation:Disconnect() end
    end
    ScreenGui:Destroy()
end

function LegendaryUI:GetVersion()
    return "2.0 - Red & Blue Edition"
end

return LegendaryUI
