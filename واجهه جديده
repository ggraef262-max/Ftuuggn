-- ==================== دوال الإعدادات ====================
local function SaveSettings()
    if writefile then
        local data = {
            UISize = SaveData.UISize,
            TabSize = SaveData.TabSize,
            Theme = SaveData.Theme,
            Flags = Flags,
            GlassEffect = SaveData.GlassEffect,
            GlowEffect = SaveData.GlowEffect
        }
        local success, encoded = pcall(HttpService.JSONEncode, HttpService, data)
        if success then
            pcall(writefile, "LegendaryUI_Settings.json", encoded)
        end
    end
end

local function LoadSettings()
    if readfile and isfile and isfile("LegendaryUI_Settings.json") then
        local success, data = pcall(readfile, "LegendaryUI_Settings.json")
        if success then
            local success2, decoded = pcall(HttpService.JSONDecode, HttpService, data)
            if success2 and type(decoded) == "table" then
                if decoded.UISize then SaveData.UISize = decoded.UISize end
                if decoded.TabSize then SaveData.TabSize = decoded.TabSize end
                if decoded.Theme and Themes[decoded.Theme] then SaveData.Theme = decoded.Theme end
                if decoded.Flags then Flags = decoded.Flags end
                if decoded.GlassEffect ~= nil then SaveData.GlassEffect = decoded.GlassEffect end
                if decoded.GlowEffect ~= nil then SaveData.GlowEffect = decoded.GlowEffect end
                CurrentTheme = Themes[SaveData.Theme]
            end
        end
    end
end

LoadSettings()

-- ==================== دوال الثيم ====================
function LegendaryUI:SetTheme(themeName)
    if not Themes[themeName] then return false end
    SaveData.Theme = themeName
    CurrentTheme = Themes[themeName]
    SaveSettings()
    
    -- تحديث جميع العناصر
    for _, item in pairs(Instances) do
        if item.Type == "Gradient" and item.Instance then
            item.Instance.Color = CurrentTheme["Color Hub 1"]
        elseif item.Type == "Frame" and item.Instance then
            item.Instance.BackgroundColor3 = CurrentTheme["Color Hub 2"]
            if SaveData.GlassEffect and item.Instance:IsA("Frame") then
                item.Instance.BackgroundTransparency = 0.85
            else
                item.Instance.BackgroundTransparency = 0
            end
        elseif item.Type == "Stroke" and item.Instance then
            item.Instance.Color = CurrentTheme["Color Stroke"]
        elseif item.Type == "Theme" and item.Instance then
            local prop = item.Instance:IsA("Frame") and "BackgroundColor3" or 
                        item.Instance:IsA("TextLabel") and "TextColor3" or
                        item.Instance:IsA("ImageLabel") and "ImageColor3" or "Color"
            item.Instance[prop] = CurrentTheme["Color Theme"]
        elseif item.Type == "Text" and item.Instance then
            item.Instance.TextColor3 = CurrentTheme["Color Text"]
        elseif item.Type == "DarkText" and item.Instance then
            item.Instance.TextColor3 = CurrentTheme["Color Dark Text"]
        elseif item.Type == "ScrollBar" and item.Instance then
            item.Instance.ScrollBarImageColor3 = CurrentTheme["Color Theme"]
        end
    end
    
    LegendaryUI:Notify({
        Title = "🎨 Theme Changed",
        Text = "تم تغيير الثيم إلى " .. CurrentTheme.Name,
        Duration = 2,
        Icon = "rbxassetid://10709790948"
    })
    return true
end

function LegendaryUI:GetTheme()
    return SaveData.Theme
end

function LegendaryUI:GetThemes()
    local themeList = {}
    for name, theme in pairs(Themes) do
        table.insert(themeList, {Name = name, Display = theme.Name})
    end
    return themeList
end

function LegendaryUI:ToggleGlass(enabled)
    SaveData.GlassEffect = enabled
    for _, item in pairs(Instances) do
        if item.Type == "Frame" and item.Instance and item.Instance:IsA("Frame") then
            if enabled then
                item.Instance.BackgroundTransparency = 0.85
            else
                item.Instance.BackgroundTransparency = 0
            end
        end
    end
    SaveSettings()
end

function LegendaryUI:ToggleGlow(enabled)
    SaveData.GlowEffect = enabled
    SaveSettings()
end

