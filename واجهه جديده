                TextSize = 32,
                BackgroundTransparency = 1
            })
            
            local buttonFrame = Create("Frame", frame, {
                Size = UDim2.new(1, -32, 0, 40),
                Position = UDim2.new(0, 16, 1, -12),
                AnchorPoint = Vector2.new(0, 1),
                BackgroundTransparency = 1
            })
            
            local startBtn = Create("TextButton", buttonFrame, {
                Size = UDim2.new(0.5, -6, 0, 40),
                Position = UDim2.new(0, 0, 0, 0),
                Text = "▶ بدء",
                BackgroundColor3 = theme.Primary,
                TextColor3 = theme.Text,
                Font = Enum.Font.GothamBold,
                TextSize = 13
            })
            Create("UICorner", startBtn, {CornerRadius = UDim.new(0, 10)})
            AddRippleEffect(startBtn)
            
            local resetBtn = Create("TextButton", buttonFrame, {
                Size = UDim2.new(0.5, -6, 0, 40),
                Position = UDim2.new(1, 0, 0, 0),
                AnchorPoint = Vector2.new(1, 0),
                Text = "↺ إعادة",
                BackgroundColor3 = Color3.fromRGB(70, 70, 70),
                TextColor3 = theme.Text,
                Font = Enum.Font.GothamBold,
                TextSize = 13
            })
            Create("UICorner", resetBtn, {CornerRadius = UDim.new(0, 10)})
            AddRippleEffect(resetBtn)
            
            local remaining = defaultTime
            local running = false
            local connection
            
            local function updateDisplay()
                timeLabel.Text = tostring(math.floor(remaining))
                if remaining <= 0 and running then
                    running = false
                    if connection then connection:Disconnect() end
                    startBtn.Text = "▶ بدء"
                    startBtn.BackgroundColor3 = theme.Primary
                    pcall(callback)
                    windowMethods:Notify({
                        Title = timerName,
                        Text = "انتهى المؤقت!",
                        Duration = 3,
                        Icon = "rbxassetid://10734984606"
                    })
                end
            end
            
            startBtn.MouseButton1Click:Connect(function()
                if SaveData.Sounds.Enabled then PlayClickSound() end
                running = not running
                if running then
                    startBtn.Text = "⏸ إيقاف"
                    startBtn.BackgroundColor3 = Color3.fromRGB(200, 70, 70)
                    connection = RunService.Heartbeat:Connect(function(dt)
                        if running and remaining > 0 then
                            remaining = remaining - dt
                            updateDisplay()
                        end
                    end)
                else
                    startBtn.Text = "▶ بدء"
                    startBtn.BackgroundColor3 = theme.Primary
                    if connection then connection:Disconnect() end
                end
            end)
            
            resetBtn.MouseButton1Click:Connect(function()
                if SaveData.Sounds.Enabled then PlayClickSound() end
                remaining = defaultTime
                updateDisplay()
                if running then
                    running = false
                    startBtn.Text = "▶ بدء"
                    startBtn.BackgroundColor3 = theme.Primary
                    if connection then connection:Disconnect() end
                end
            end)
            
            local element = {Frame = frame, UpdateTheme = function(newTheme)
                frame.BackgroundColor3 = newTheme.Surface
                titleLabel.TextColor3 = newTheme.Text
                if descLabel then descLabel.TextColor3 = newTheme.TextDim end
                timeLabel.TextColor3 = newTheme.Primary
                startBtn.BackgroundColor3 = newTheme.Primary
                startBtn.TextColor3 = newTheme.Text
                resetBtn.TextColor3 = newTheme.Text
            end}
            table.insert(elements, element)
            table.insert(LegendaryUI.Instances, element)
            
            function element:SetTime(newTime)
                defaultTime = newTime
                remaining = newTime
                updateDisplay()
            end
            
            function element:Destroy()
                if connection then connection:Disconnect() end
                frame:Destroy()
            end
            
            return element
        end
        
