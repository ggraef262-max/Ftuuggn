                BackgroundColor3 = CurrentTheme["Color Theme"],
                Text = ""
            })
            Create("UICorner", sliderBtn, {CornerRadius = UDim.new(1, 0)})
            
            local function updateSlider(newValue)
                value = math.clamp(newValue, min, max)
                if config.Flag then Flags[config.Flag] = value end
                if config.Callback then pcall(config.Callback, value) end
                valueLabel.Text = tostring(math.floor(value))
                local percent = (value - min) / (max - min)
                fill.Size = UDim2.new(percent, 0, 1, 0)
                sliderBtn.Position = UDim2.new(percent, -7, 0.5, 0)
            end
            
            sliderBtn.MouseButton1Down:Connect(function()
                local conn
                conn = UserInputService.InputChanged:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseMovement then
                        local mousePos = UserInputService:GetMouseLocation()
                        local barPos = sliderBar.AbsolutePosition.X
                        local barWidth = sliderBar.AbsoluteSize.X
                        local percent = math.clamp((mousePos.X - barPos) / barWidth, 0, 1)
                        updateSlider(min + (max - min) * percent)
                    end
                end)
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        conn:Disconnect()
                    end
                end)
            end)
