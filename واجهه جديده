                Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
                BackgroundColor3 = CurrentTheme["Color Theme"]
            })
            Create("UICorner", fill, {CornerRadius = UDim.new(1, 0)})
            
            local sliderBtn = Create("TextButton", sliderBar, {
                Size = UDim2.new(0, 14, 0, 14),
                Position = UDim2.new((value - min) / (max - min), -7, 0.5, 0),
