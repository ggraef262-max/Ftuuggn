local SaveData = {
    Window = {Size = {550, 420}, TabSize = 150},
    Theme = "Crimson",
    Flags = {},
    Notifications = true
}

local function GetTheme()
    return Themes[SaveData.Theme]
end

local function SaveSettings()
    if writefile then
        local success, data = pcall(HttpService.JSONEncode, HttpService, {
            Theme = SaveData.Theme,
            Flags = SaveData.Flags
        })
        if success then pcall(writefile, "LegendaryUI.json", data) end
    end
end

local function LoadSettings()
    if readfile and isfile and isfile("LegendaryUI.json") then
        local success, data = pcall(readfile, "LegendaryUI.json")
        if success then
            local success2, decoded = pcall(HttpService.JSONDecode, HttpService, data)
            if success2 then
                if decoded.Theme and Themes[decoded.Theme] then SaveData.Theme = decoded.Theme end
                if decoded.Flags then SaveData.Flags = decoded.Flags end
            end
        end
    end
end
LoadSettings()

-- ==================================================== دوال مساعدة ====================================================
local function Create(instanceType, parent, props)
    local new = Instance.new(instanceType)
    if parent then new.Parent = parent end
    if props then for prop, val in pairs(props) do new[prop] = val end end
    return new
end

local function Tween(instance, prop, value, time)
    local tween = TweenService:Create(instance, TweenInfo.new(time or 0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {[prop] = value})
    tween:Play()
    return tween
end

local function GetStr(val) return type(val) == "function" and val() or val end

