local function CreateParticle(parent, position, color, size)
    if not SaveData.Particles.Enabled then return end
    
    local particle = Create("Frame", parent, {
        Size = UDim2.new(0, size or 4, 0, size or 4),
        Position = position,
        BackgroundColor3 = color or GetTheme().Glow,
        BackgroundTransparency = 0.5,
        ZIndex = 999
    })
    Create("UICorner", particle, {CornerRadius = UDim.new(1, 0)})
    
    CreateTween(particle, "Position", UDim2.new(position.X.Scale, position.X.Offset + math.random(-50, 50), 
        position.Y.Scale, position.Y.Offset + math.random(-50, 50)), 0.5, Enum.EasingStyle.Quad)
    CreateTween(particle, "BackgroundTransparency", 1, 0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In, true)
    particle:Destroy()
end

local function PlayClickSound()
    if not SaveData.Sounds.Enabled then return end
    local sound = Create("Sound", SoundService, {
        SoundId = SaveData.Sounds.ClickSound,
        Volume = SaveData.Sounds.Volume,
        PlayOnRemove = true
    })
    sound:Play()
    task.delay(1, function() sound:Destroy() end)
end

local function AddParticleEffect(button)
    button.MouseButton1Click:Connect(function()
        local pos = button.AbsolutePosition
        local size = button.AbsoluteSize
        for i = 1, 10 do
            task.spawn(function()
                CreateParticle(button, UDim2.new(0, math.random(0, size.X), 0, math.random(0, size.Y)), 
                    GetTheme().Glow, math.random(2, 6))
            end)
        end
    end)
end

local function AddRippleEffect(button)
    button.MouseButton1Click:Connect(function()
        local ripple = Create("Frame", button, {
            Size = UDim2.new(0, 0, 0, 0),
            Position = UDim2.new(0.5, 0, 0.5, 0),
            AnchorPoint = Vector2.new(0.5, 0.5),
            BackgroundColor3 = Color3.fromRGB(255, 255, 255),
            BackgroundTransparency = 0.7,
            ZIndex = 10
        })
        Create("UICorner", ripple, {CornerRadius = UDim.new(1, 0)})
        
        CreateTween(ripple, "Size", UDim2.new(0, 150, 0, 150), 0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, false)
        CreateTween(ripple, "BackgroundTransparency", 1, 0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, true)
        ripple:Destroy()
    end)
end

local function AddHoverEffect(button, color)
    local originalColor = button.BackgroundColor3
    local originalSize = button.Size
    local hoverColor = color or GetTheme().Accent
    
    button.MouseEnter:Connect(function()
        if SaveData.Animations.Enabled then
            CreateTween(button, "BackgroundColor3", hoverColor, 0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, false)
            CreateTween(button, "Size", UDim2.new(originalSize.X.Scale, originalSize.X.Offset + 2, 
                originalSize.Y.Scale, originalSize.Y.Offset + 2), 0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, false)
        else
            button.BackgroundColor3 = hoverColor
        end
    end)
    
    button.MouseLeave:Connect(function()
        if SaveData.Animations.Enabled then
            CreateTween(button, "BackgroundColor3", originalColor, 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, false)
            CreateTween(button, "Size", originalSize, 0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, false)
        else
            button.BackgroundColor3 = originalColor
        end
    end)
end

