            local fill = Create("Frame", sliderBar, {
                Size = UDim2.new((default - min) / (max - min), 0, 1, 0),
                BackgroundColor3 = CurrentTheme["Color Theme"]
            })
            Create("UICorner", fill, {CornerRadius = UDim.new(1, 0)})
            
            local sliderButton = Create("TextButton", sliderBar, {
                Size = UDim2.new(0, 16, 0, 16),
                Position = UDim2.new((default - min) / (max - min), -8, 0.5, 0),
                AnchorPoint = Vector2.new(0, 0.5),
                BackgroundColor3 = CurrentTheme["Color Theme"],
                Text = ""
            })
            Create("UICorner", sliderButton, {CornerRadius = UDim.new(1, 0)})
            AddGlowEffect(sliderButton, CurrentTheme["Color Glow"])
            
            local value = default
            
            local function updateSlider(newValue)
                value = math.clamp(newValue, min, max)
                if flag then Flags[flag] = value end
                pcall(callback, value)
                SaveSettings()
                valueLabel.Text = tostring(value)
                local percent = (value - min) / (max - min)
                fill.Size = UDim2.new(percent, 0, 1, 0)
                sliderButton.Position = UDim2.new(percent, -8, 0.5, 0)
            end
            
            sliderButton.MouseButton1Down:Connect(function()
