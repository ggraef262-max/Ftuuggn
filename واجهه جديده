    glowAnim = RunService.RenderStepped:Connect(function()
        if progressBar and progressBar.Parent then
            local newPos = (progressBar.Size.X.Scale * 100) / 100
            progressGlow.Position = UDim2.new(newPos - 0.2, 0, -0.5, 0)
        else
            if glowAnim then glowAnim:Disconnect() end
        end
    end)
    
    -- أنيميشن الدخول
    notification.Position = UDim2.new(1, 50, 0, 0)
    CreateEasingTween(notification, "Position", UDim2.new(0, 0, 0, 0), 0.4, Enum.EasingStyle.Back)
    CreateTween(notification, "BackgroundTransparency", SaveData.Window.GlassIntensity > 0 and 0.85 or 0, 0.3)
    
    -- صوت
    if sound then
        PlayClickSound()
    end
    
    closeBtn.MouseButton1Click:Connect(function()
        if glowAnim then glowAnim:Disconnect() end
        CreateEasingTween(notification, "Position", UDim2.new(1, 50, 0, 0), 0.3, Enum.EasingStyle.Back)
        CreateTween(notification, "BackgroundTransparency", 1, 0.2)
        task.wait(0.35)
        container:Destroy()
    end)
    
    task.spawn(function()
        task.wait(duration)
        if container.Parent then
            if glowAnim then glowAnim:Disconnect() end
            CreateEasingTween(notification, "Position", UDim2.new(1, 50, 0, 0), 0.35, Enum.EasingStyle.Back)
            CreateTween(notification, "BackgroundTransparency", 1, 0.2)
            task.wait(0.4)
            container:Destroy()
        end
    end)
    
    return {Close = function() closeBtn.MouseButton1Click:Fire() end}
end

-- ==================================================== دوال الإعدادات ====================================================
local function SaveSettings()
    if writefile then
        local data = {
            Window = SaveData.Window,
            Theme = SaveData.Theme,
            Flags = SaveData.Flags,
            Notifications = SaveData.Notifications,
            Animations = SaveData.Animations,
            Sounds = SaveData.Sounds,
            Particles = SaveData.Particles
        }
        local success, encoded = pcall(HttpService.JSONEncode, HttpService, data)
        if success then
            pcall(writefile, "LegendaryUI_Ultimate.json", encoded)
        end
    end
end

local function LoadSettings()
    if readfile and isfile and isfile("LegendaryUI_Ultimate.json") then
        local success, data = pcall(readfile, "LegendaryUI_Ultimate.json")
        if success then
            local success2, decoded = pcall(HttpService.JSONDecode, HttpService, data)
            if success2 and type(decoded) == "table" then
                if decoded.Window then
                    for k, v in pairs(decoded.Window) do
                        SaveData.Window[k] = v
                    end
                end
                if decoded.Theme and Themes[decoded.Theme] then SaveData.Theme = decoded.Theme end
                if decoded.Flags then SaveData.Flags = decoded.Flags end
                if decoded.Notifications then
                    for k, v in pairs(decoded.Notifications) do
                        SaveData.Notifications[k] = v
                    end
                end
                if decoded.Animations then
                    for k, v in pairs(decoded.Animations) do
                        SaveData.Animations[k] = v
                    end
                end
                if decoded.Sounds then
                    for k, v in pairs(decoded.Sounds) do
                        SaveData.Sounds[k] = v
                    end
                end
                if decoded.Particles then
                    for k, v in pairs(decoded.Particles) do
                        SaveData.Particles[k] = v
                    end
                end
            end
        end
    end
end

LoadSettings()

-- ==================================================== دوال الثيم ====================================================
function LegendaryUI:SetTheme(themeName)
    if not Themes[themeName] then return false end
    
    SaveData.Theme = themeName
    local theme = Themes[themeName]
    SaveSettings()
    
    -- تحديث جميع العناصر
    for _, element in pairs(self.Instances or {}) do
        if element.UpdateTheme then
            element:UpdateTheme(theme)
        end
    end
    
    self:Notify({
        Title = "🎨 Theme Changed",
        Text = "تم تغيير الثيم إلى " .. theme.Name,
        Duration = 2,
        Icon = "rbxassetid://10709790948"
    })
    
    return true
end

function LegendaryUI:GetTheme()
    return SaveData.Theme
end

function LegendaryUI:GetThemes()
    local list = {}
    for name, theme in pairs(Themes) do
        table.insert(list, {Name = name, Display = theme.Name, Color = theme.Primary})
    end
    return list
end

-- ==================================================== دوال التحكم ====================================================
function LegendaryUI:GetFlag(name)
    return SaveData.Flags[name]
end

function LegendaryUI:SetFlag(name, value)
    SaveData.Flags[name] = value
    SaveSettings()
    return value
end

function LegendaryUI:ToggleSound(enabled)
    SaveData.Sounds.Enabled = enabled
    SaveSettings()
end

function LegendaryUI:ToggleParticles(enabled)
    SaveData.Particles.Enabled = enabled
    SaveSettings()
end

function LegendaryUI:ToggleAnimations(enabled)
    SaveData.Animations.Enabled = enabled
    SaveSettings()
end

function LegendaryUI:SetAnimationSpeed(speed)
    SaveData.Animations.Speed = Clamp(speed, 0.1, 0.8)
    SaveSettings()
end

