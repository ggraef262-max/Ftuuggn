-- الطيران
FlyConnection = RunService.Heartbeat:Connect(function(deltaTime)
    if not FlyState or not RootPart or not Humanoid then return end

    Humanoid.PlatformStand = true
    Humanoid.WalkSpeed = 0

    local moveDirection = Vector3.new(0, 0, 0)
    local speed = FlySpeed * deltaTime * 60

    if UserInputService:IsKeyDown(Enum.KeyCode.W) then
        moveDirection = moveDirection + Camera.CFrame.LookVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then
        moveDirection = moveDirection - Camera.CFrame.LookVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then
        moveDirection = moveDirection - Camera.CFrame.RightVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then
        moveDirection = moveDirection + Camera.CFrame.RightVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
        moveDirection = moveDirection + Vector3.new(0, 1, 0)
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
        moveDirection = moveDirection - Vector3.new(0, 1, 0)
    end

    if moveDirection.Magnitude > 0 then
        moveDirection = moveDirection.Unit * speed
        RootPart.CFrame = RootPart.CFrame + moveDirection
    end
end)

-- السرعة
RunService.Heartbeat:Connect(function()
    if SpeedState and Humanoid then
        Humanoid.WalkSpeed = SpeedValue
    elseif Humanoid and not SpeedState then
        Humanoid.WalkSpeed = 16
    end
end)

-- الاختراق
NoclipConnection = RunService.Stepped:Connect(function()
    if NoclipState and Character then
        for _, part in pairs(Character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
end)

-- الجمع التلقائي
FarmConnection = RunService.Heartbeat:Connect(function()
    if not AutoFarmState or not RootPart then return end
    
    local closestDist = math.huge
    local closestObj = nil
    
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Part") and obj:FindFirstChild("TouchInterest") and obj.Transparency < 1 then
            local dist = (RootPart.Position - obj.Position).Magnitude
            if dist < closestDist then
                closestDist = dist
                closestObj = obj
            end
        end
    end
    
    if closestObj and closestDist > 10 then
        local tween = TweenService:Create(RootPart, TweenInfo.new(0.3), {CFrame = CFrame.lookAt(RootPart.Position, closestObj.Position) * CFrame.new(0, 0, -5)})
        tween:Play()
    end
end)

