-- ═══════════════════════════════════════════════
-- دالة إنشاء تأثيرات بصرية
-- ═══════════════════════════════════════════════

local function createVisualEffect(position, color, effectType)
    if effectType == "teleport" then
        -- تأثير الانتقال السريع
        local part = Instance.new("Part")
        part.Size = Vector3.new(2, 2, 2)
        part.Position = position
        part.Anchored = true
        part.CanCollide = false
        part.Transparency = 0.3
        part.BrickColor = BrickColor.new(color)
        part.Material = Enum.Material.Neon
        part.Parent = workspace
        
        -- إضافة ضوء
        local light = Instance.new("PointLight")
        light.Color = color
        light.Range = 10
        light.Brightness = 1
        light.Parent = part
        
        -- تأثير تمدد وانكماش
        local tween1 = TweenService:Create(part, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {Size = Vector3.new(4, 4, 4), Transparency = 0.7})
        local tween2 = TweenService:Create(part, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {Size = Vector3.new(1, 1, 1), Transparency = 1})
        
        tween1:Play()
        tween1.Completed:Connect(function()
            tween2:Play()
            tween2.Completed:Connect(function()
                part:Destroy()
            end)
        end)
        
        Debris:AddItem(part, 1)
    end
end

-- ═══════════════════════════════════════════════
-- دالة الحماية من الموت تحت الأرض (الميزة الجديدة)
-- ═══════════════════════════════════════════════

local function setupAntiVoid()
    AntiVoidConnection = RunService.Heartbeat:Connect(function()
        if not AntiVoidState or not RootPart or not Humanoid then return end
        if Humanoid.Health <= 0 then return end
        
        local currentPos = RootPart.Position
        
        -- التحقق من السقوط في الفراغ
        if currentPos.Y < AntiVoidHeight then
            -- البحث عن أقرب سطح آمن
            local ray = Ray.new(currentPos + Vector3.new(0, 10, 0), Vector3.new(0, -100, 0))
            local hit, position = workspace:FindPartOnRay(ray, Character)
            
            if hit then
                -- إذا وجد سطح، انقل له
                local safePos = Vector3.new(currentPos.X, position.Y + 5, currentPos.Z)
                
                -- إنشاء تأثير انتقال
                createVisualEffect(RootPart.Position, Color3.fromRGB(0, 255, 255), "teleport")
                createVisualEffect(safePos, Color3.fromRGB(0, 255, 255), "teleport")
                
                -- نقل اللاعب
                RootPart.CFrame = CFrame.new(safePos)
                
                -- إعطاء دفعة مؤقتة
                Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                
                -- رسالة تحذير
                if Player.PlayerGui:FindFirstChild("DragonHackGUI") then
                    local warning = Instance.new("Frame")
                    warning.Size = UDim2.new(0, 200, 0, 40)
                    warning.Position = UDim2.new(0.5, -100, 0.2, 0)
                    warning.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
                    warning.BackgroundTransparency = 0.2
                    warning.BorderSizePixel = 0
                    warning.Parent = Player.PlayerGui.DragonHackGUI
                    
                    local corner = Instance.new("UICorner")
                    corner.CornerRadius = UDim.new(0, 10)
                    corner.Parent = warning
                    
                    local text = Instance.new("TextLabel")
                    text.Size = UDim2.new(1, 0, 1, 0)
                    text.BackgroundTransparency = 1
                    text.Text = "🚫 تم إنقاذك من الموت!"
                    text.TextColor3 = Color3.new(1, 1, 1)
                    text.TextScaled = true
                    text.Font = Enum.Font.GothamBold
                    text.Parent = warning
                    
                    -- إخفاء بعد ثانيتين
                    wait(2)
                    warning:Destroy()
                end
            else
                -- إذا ما في سطح، ارفعه للأعلى
                RootPart.CFrame = RootPart.CFrame + Vector3.new(0, 20, 0)
            end
        end
        
        -- حفظ آخر موقع آمن
        if currentPos.Y > 100 then
            LastPosition = currentPos
        end
    end)
end

-- ═══════════════════════════════════════════════
-- دالة تتبع الصناديق المحسنة (3D ESP)
-- ═══════════════════════════════════════════════

local function setupChestESP()
    local espFolder = CoreGui:FindFirstChild("ESPChests")
    if not espFolder then
        espFolder = Instance.new("Folder")
        espFolder.Name = "ESPChests"
        espFolder.Parent = CoreGui
    end

    -- دالة إنشاء خط متوهج
    local function createGlowLine(color)
        local line = Instance.new("Frame")
        line.Name = "GlowLine"
        line.BackgroundColor3 = color
        line.BorderSizePixel = 0
        line.BackgroundTransparency = 0.3
        line.Parent = espFolder
        return line
    end

    -- دالة إنشاء مربع ثلاثي الأبعاد
    local function create3DBox(targetPart, color)
        local box = Instance.new("BoxHandleAdornment")
        box.Name = "3DBox"
        box.Size = targetPart.Size + Vector3.new(1, 1, 1)
        box.Color3 = color
        box.Transparency = 0.3
        box.ZIndex = 10
        box.Adornee = targetPart
        box.AlwaysOnTop = true
        box.Visible = true
        box.Parent = espFolder
        
        -- إضافة توهج
        local glow = Instance.new("BoxHandleAdornment")
        glow.Name = "Glow"
        glow.Size = targetPart.Size + Vector3.new(1.5, 1.5, 1.5)
        glow.Color3 = color
        glow.Transparency = 0.7
        glow.ZIndex = 5
        glow.Adornee = targetPart
        glow.AlwaysOnTop = true
        glow.Visible = true
        glow.Parent = espFolder
        
        return {box, glow}
    end

    -- دالة البحث عن الصناديق
    local function findChests()
        local chests = {}
        local chestKeywords = {"chest", "box", "treasure", "crate", "صندوق", "كنز"}
        
        for _, obj in pairs(workspace:GetDescendants()) do
            local nameLower = obj.Name:lower()
            for _, keyword in pairs(chestKeywords) do
                if nameLower:find(keyword) then
                    if obj:IsA("Part") and obj.Transparency < 1 then
                        table.insert(chests, obj)
                    elseif obj:IsA("Model") and obj.PrimaryPart then
                        table.insert(chests, obj)
                    end
                    break
                end
            end
        end
        return chests
    end

    -- تحديث ESP
    ESPConnection = RunService.RenderStepped:Connect(function()
        -- تنظيف
        for _, obj in pairs(ESPObjects) do
            if obj and obj.Parent then
                obj:Destroy()
            end
        end
        ESPObjects = {}
        
        if ChestESPState and RootPart then
            local chests = findChests()
            
            for _, chest in pairs(chests) do
                local chestPos = chest:IsA("Model") and chest.PrimaryPart.Position or chest.Position
                local distance = (RootPart.Position - chestPos).Magnitude
                
                -- تحديد اللون حسب المسافة والقيمة
                local color
                if distance < 50 then
                    color = Color3.fromRGB(255, 50, 50) -- أحمر قريب
                elseif distance < 150 then
                    color = Color3.fromRGB(255, 200, 50) -- برتقالي
                else
                    color = Color3.fromRGB(50, 255, 50) -- أخضر بعيد
                end
                
                -- إنشاء الخطوط
                local line = createGlowLine(color)
                ESPObjects[#ESPObjects + 1] = line
                
                -- إنشاء المربعات
                if chest:IsA("Part") then
                    local boxes = create3DBox(chest, color)
                    for _, box in pairs(boxes) do
                        ESPObjects[#ESPObjects + 1] = box
                    end
                end
                
                -- تحديث الخط في كل إطار
                RunService.RenderStepped:Connect(function()
                    if line and line.Parent and RootPart then
                        local startPos = Camera:WorldToViewportPoint(RootPart.Position)
                        local endPos = Camera:WorldToViewportPoint(chestPos)
                        
                        if startPos.Z > 0 and endPos.Z > 0 then
                            local distance2D = (Vector2.new(endPos.X, endPos.Y) - Vector2.new(startPos.X, startPos.Y)).Magnitude
                            local angle = math.atan2(endPos.Y - startPos.Y, endPos.X - startPos.X)
                            
                            line.Size = UDim2.new(0, distance2D, 0, 3)
                            line.Position = UDim2.new(0, startPos.X, 0, startPos.Y)
                            line.Rotation = math.deg(angle)
                            line.Visible = true
                            
                            -- إضافة نص المسافة
                            if not line:FindFirstChild("DistanceLabel") then
                                local label = Instance.new("TextLabel")
                                label.Name = "DistanceLabel"
                                label.Size = UDim2.new(0, 50, 0, 20)
                                label.BackgroundTransparency = 1
                                label.TextColor3 = color
                                label.Text = math.floor(distance) .. "m"
                                label.TextScaled = true
                                label.Font = Enum.Font.GothamBold
                                label.Parent = line
                            else
                                line.DistanceLabel.Text = math.floor(distance) .. "m"
                                line.DistanceLabel.Position = UDim2.new(0.5, -25, 0.5, -10)
                            end
                        else
                            line.Visible = false
                        end
                    end
                end)
            end
        end
    end)
end

