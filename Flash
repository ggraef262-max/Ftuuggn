local GetFlag, SetFlag, CheckFlag do
    CheckFlag = function(Name)
        return type(Name) == "string" and Flags[Name] ~= nil
    end
    
    GetFlag = function(Name)
        return type(Name) == "string" and Flags[Name]
    end
    
