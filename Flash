        if not Particles.enabled or #Particles.active >= ParticleConfig.MaxParticles then return end
        
        local size = math.random(ParticleConfig.Size.Min, ParticleConfig.Size.Max)
        local startX = math.random(10, ParticleContainer.AbsoluteSize.X - 10)
        local startY = ParticleContainer.AbsoluteSize.Y + 10
        local speed = math.random(ParticleConfig.Speed.Min, ParticleConfig.Speed.Max)
        
