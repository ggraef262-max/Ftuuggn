                Font = Enum.Font.GothamBold, Text = Name,
                TextColor3 = Color3.fromRGB(255,215,0), Size = UDim2.new(1,-25,1,0),
                Position = UDim2.new(0,5), BackgroundTransparency = 1,
                TextSize = 18, TextXAlignment = "Left"
