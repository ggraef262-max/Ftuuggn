function redzlib:SetTheme(NewTheme)
    if not self.Themes[NewTheme] then return end
    
    self.Save.Theme = NewTheme
    local Theme = self.Themes[NewTheme]
    
    self.CustomColors.MainColor = Theme["Color Hub 2"]
    self.CustomColors.StrokeColor = Theme["Color Stroke"]
    self.CustomColors.ThemeColor = Theme["Color Theme"]
    self.CustomColors.TextColor = Theme["Color Text"]
    self.CustomColors.DarkTextColor = Theme["Color Dark Text"]
    
    for _, item in ipairs(self.Instances) do
        if item.Type == "Gradient" then
            item.Instance.Color = Theme["Color Hub 1"]
        elseif item.Type == "Frame" then
            item.Instance.BackgroundColor3 = Theme["Color Hub 2"]
        elseif item.Type == "Stroke" then
            item.Instance.Color = Theme["Color Stroke"]
        elseif item.Type == "Theme" then
            item.Instance.BackgroundColor3 = Theme["Color Theme"]
        elseif item.Type == "Text" then
            item.Instance.TextColor3 = Theme["Color Text"]
        elseif item.Type == "DarkText" then
            item.Instance.TextColor3 = Theme["Color Dark Text"]
        elseif item.Type == "ScrollBar" then
            item.Instance.ScrollBarImageColor3 = Theme["Color Theme"]
        end
    end
end

-- ===================================================================
-- [[ دالة تغيير اللون المخصص ]]
-- ===================================================================
function redzlib:SetCustomColor(colorType, newColor)
    if not newColor then return end
    
    if colorType == "Main" then
        self.CustomColors.MainColor = newColor
        for _, item in ipairs(self.Instances) do
            if item.Type == "Frame" then
                item.Instance.BackgroundColor3 = newColor
            end
        end
    elseif colorType == "Stroke" then
        self.CustomColors.StrokeColor = newColor
        for _, item in ipairs(self.Instances) do
            if item.Type == "Stroke" then
                item.Instance.Color = newColor
            end
        end
    elseif colorType == "Theme" then
        self.CustomColors.ThemeColor = newColor
        for _, item in ipairs(self.Instances) do
            if item.Type == "Theme" then
                item.Instance.BackgroundColor3 = newColor
            elseif item.Type == "ScrollBar" then
                item.Instance.ScrollBarImageColor3 = newColor
            end
        end
    end
end

