                Size = UDim2.new(0, 40, 0, 20),
                Position = UDim2.new(1, -12, 0.5),
                AnchorPoint = Vector2.new(1, 0.5),
                BackgroundTransparency = 1,
                Font = Enum.Font.FredokaOne,
                Text = tostring(default),
                TextColor3 = Theme["Color Theme"],
                TextSize = 14,
                TextXAlignment = "Right"
            }), "Theme")
            
            local sliderBar = InsertTheme(Create("Frame", slider, {
                Size = UDim2.new(1, -80, 0, 6),
                Position = UDim2.new(0, 12, 0.5, 0),
                AnchorPoint = Vector2.new(0, 0.5),
                BackgroundColor3 = Theme["Color Stroke"]
            }), "Stroke")
            Make("Corner", sliderBar, UDim.new(0.5, 0))
            
            local sliderFill = InsertTheme(Create("Frame", sliderBar, {
                Size = UDim2.new((default - min) / (max - min), 0, 1, 0),
                BackgroundColor3 = Theme["Color Theme"],
                BorderSizePixel = 0
            }), "Theme")
            Make("Corner", sliderFill, UDim.new(0.5, 0))
            
            local sliderKnob = Create("Frame", sliderBar, {
                Size = UDim2.new(0, 8, 0, 14),
                Position = UDim2.new((default - min) / (max - min), 0, 0.5),
                AnchorPoint = Vector2.new(0.5, 0.5),
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                BackgroundTransparency = 0.1
            })
            Make("Corner", sliderKnob, UDim.new(0.5, 0))
            
            local dragging = false
            
            local function UpdateValue(input)
                local pos = input.Position.X - sliderBar.AbsolutePosition.X
                local percent = math.clamp(pos / sliderBar.AbsoluteSize.X, 0, 1)
                local value = math.floor(min + (max - min) * percent)
                
                if value ~= default then
                    default = value
                    valueLabel.Text = tostring(value)
                    sliderFill.Size = UDim2.new(percent, 0, 1, 0)
                    sliderKnob.Position = UDim2.new(percent, 0, 0.5)
                    callback(value)
                    SetFlag(flag, value)
                end
            end
            
            sliderBar.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = true
                    UpdateValue(input)
                end
            end)
            
            sliderBar.InputChanged:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseMovement and dragging then
                    UpdateValue(input)
                end
            end)
            
            sliderBar.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = false
                end
            end)
            
            local SliderObj = {
                Set = function(_, value)
                    if type(value) == "number" then
                        value = math.clamp(value, min, max)
                        default = value
                        valueLabel.Text = tostring(value)
                        local percent = (value - min) / (max - min)
                        sliderFill.Size = UDim2.new(percent, 0, 1, 0)
                        sliderKnob.Position = UDim2.new(percent, 0, 0.5)
                        callback(value)
                        SetFlag(flag, value)
                    end
                end,
                Get = function() return default end,
                Visible = function(_, bool) slider.Visible = bool end,
                Destroy = function() slider:Destroy() end
            }
            return SliderObj
        end
        
