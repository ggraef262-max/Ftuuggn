-- دوال مساعدة
function redzlib:GetIcon(index)
    if type(index) ~= "string" or index:find("rbxassetid://") then
        return index
    end
    
    index = string.lower(index):gsub("-", "")
    
    if self.Icons[index] then
        return self.Icons[index]
    end
    
    for name, icon in pairs(self.Icons) do
        if name:find(index, 1, true) then
            return icon
        end
    end
    
    return index
end

function redzlib:SetScale(scale)
    UIScale = ViewportSize.Y / math.clamp(scale, 300, 2000)
    ScreenGui.Scale.Scale = UIScale
end

return redzlib
