    function Window:MakeTab(Configs)
        local TName = Configs[1] or Configs.Title or "Tab"
        local TIcon = Configs[2] or Configs.Icon or ""

        local TabSelect = Create("Frame", MainScroll, { Size = UDim2.new(1,0,0,35), BackgroundTransparency = 1 })
        local TabButton = Make("Button", TabSelect, { Size = UDim2.new(1,0,1,0) })
        Make("Corner", TabButton, UDim.new(0,12))

        local LabelTitle = InsertTheme(Create("TextLabel", TabButton, {
            Size = UDim2.new(1, TIcon and -35 or -20, 1),
            Position = UDim2.fromOffset(TIcon and 35 or 15),
            BackgroundTransparency = 1, Font = Enum.Font.GothamBold,
            Text = TName, TextColor3 = Color3.new(1,1,1), TextSize = 13,
            TextXAlignment = "Left", TextTransparency = (FirstTab and 0.3) or 0
        }), "Text")

        local Selected = InsertTheme(Create("Frame", TabButton, {
            Size = FirstTab and UDim2.new(0,4,0,4) or UDim2.new(0,4,0,25),
            Position = UDim2.new(1,-10,0.5), AnchorPoint = Vector2.new(1,0.5),
            BackgroundColor3 = Color3.fromRGB(255,215,0),
            BackgroundTransparency = FirstTab and 1 or 0
        }), "Theme")
        Make("Corner", Selected, UDim.new(0.5,0))

        local Container = InsertTheme(Create("ScrollingFrame", nil, {
            Size = UDim2.new(1,0,1,0), Position = UDim2.new(0,0,1),
            AnchorPoint = Vector2.new(0,1), ScrollBarThickness = 4,
            BackgroundTransparency = 1, ScrollBarImageColor3 = Color3.fromRGB(255,215,0),
            AutomaticCanvasSize = "Y", BorderSizePixel = 0,
            Name = "Container - "..TName
        }, {
            Create("UIPadding", { PaddingLeft = UDim.new(0,15), PaddingRight = UDim.new(0,15),
                                  PaddingTop = UDim.new(0,15), PaddingBottom = UDim.new(0,15) }),
            Create("UIListLayout", { Padding = UDim.new(0,10) })
        }), "ScrollBar")

        table.insert(ContainerList, Container)
        if not FirstTab then Container.Parent = Containers end

        local function Tabs()
            if Container.Parent then return end
            for _,f in pairs(ContainerList) do if f ~= Container then f.Parent = nil end end
            Container.Parent = Containers
            CreateTween({LabelTitle, "TextTransparency", 0, 0.35})
            CreateTween({Selected, "Size", UDim2.new(0,4,0,25), 0.35})
            CreateTween({Selected, "BackgroundTransparency", 0, 0.35})
        end
        TabButton.Activated:Connect(Tabs)

        FirstTab = false
        local Tab = {}
        table.insert(self.Tabs, { func = Tab, Cont = Container })

        function Tab:AddSection(Configs)
            local Name = type(Configs)=="string" and Configs or Configs[1]
            local Section = Create("Frame", Container, { Size = UDim2.new(1,0,0,30), BackgroundTransparency = 1 })
            Create("Frame", Section, {
