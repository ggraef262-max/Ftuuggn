function Window:MakeTab(config)
    local tabName = config.Title or config[1] or "Tab"
    local tabIcon = config.Icon or config[2] or ""

    -- زر التبويب
    local TabButton = Instance.new("TextButton")
    TabButton.Size = UDim2.new(1, 0, 0, 35)
    TabButton.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    TabButton.BackgroundTransparency = 0.2
    TabButton.AutoButtonColor = false
    TabButton.Parent = TabScroll
    TabButton.Text = ""
    
    local TabCorner = Instance.new("UICorner")
    TabCorner.CornerRadius = UDim.new(0, 12)
    TabCorner.Parent = TabButton
    
    local TabStroke = Instance.new("UIStroke")
    TabStroke.Color = Color3.fromRGB(218, 165, 32)
    TabStroke.Thickness = 1.5
    TabStroke.Parent = TabButton
    
    -- نص التبويب
    local TabLabel = Instance.new("TextLabel")
    TabLabel.Size = UDim2.new(1, -35, 1, 0)
    TabLabel.Position = UDim2.new(0, 35, 0, 0)
    TabLabel.BackgroundTransparency = 1
    TabLabel.Text = tabName
    TabLabel.TextColor3 = Color3.new(1, 1, 1)
    TabLabel.TextSize = 13
    TabLabel.Font = Enum.Font.GothamBold
    TabLabel.TextXAlignment = "Left"
    TabLabel.Parent = TabButton
    
    -- المؤشر الجانبي
    local TabIndicator = Instance.new("Frame")
    TabIndicator.Size = FirstTab and UDim2.new(0, 4, 0, 4) or UDim2.new(0, 4, 0, 25)
    TabIndicator.Position = UDim2.new(1, -10, 0.5)
    TabIndicator.AnchorPoint = Vector2.new(1, 0.5)
    TabIndicator.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
    TabIndicator.BackgroundTransparency = FirstTab and 1 or 0
    TabIndicator.Parent = TabButton
    
    local IndicatorCorner = Instance.new("UICorner")
    IndicatorCorner.CornerRadius = UDim.new(0.5, 0)
    IndicatorCorner.Parent = TabIndicator
    
    -- حاوية المحتوى
    local Container = Instance.new("ScrollingFrame")
    Container.Size = UDim2.new(1, 0, 1, 0)
    Container.BackgroundTransparency = 1
    Container.ScrollBarThickness = 4
    Container.ScrollBarImageColor3 = Color3.fromRGB(255, 215, 0)
    Container.CanvasSize = UDim2.new(0, 0, 0, 0)
    Container.AutomaticCanvasSize = Enum.AutomaticSize.Y
    Container.BorderSizePixel = 0
    Container.Parent = FirstTab and ContainerFrame or nil
    
    local ContainerPadding = Instance.new("UIPadding")
    ContainerPadding.PaddingLeft = UDim.new(0, 15)
    ContainerPadding.PaddingRight = UDim.new(0, 15)
    ContainerPadding.PaddingTop = UDim.new(0, 15)
    ContainerPadding.PaddingBottom = UDim.new(0, 15)
    ContainerPadding.Parent = Container
    
    local ContainerLayout = Instance.new("UIListLayout")
    ContainerLayout.Padding = UDim.new(0, 10)
    ContainerLayout.Parent = Container
    
    table.insert(Containers, Container)
    
    -- وظيفة التبديل بين التبويبات
    local function SelectTab()
        for _, c in ipairs(Containers) do
            c.Parent = nil
        end
        Container.Parent = ContainerFrame
        
        for _, btn in ipairs(TabScroll:GetChildren()) do
            if btn:IsA("TextButton") then
                local indicator = btn:FindFirstChildOfClass("Frame")
                if indicator then
                    CreateTween(indicator, "Size", UDim2.new(0, 4, 0, 4), 0.3)
                    CreateTween(indicator, "BackgroundTransparency", 1, 0.3)
                end
                local label = btn:FindFirstChildOfClass("TextLabel")
                if label then
                    CreateTween(label, "TextTransparency", 0.3, 0.3)
                end
            end
        end
        
        CreateTween(TabIndicator, "Size", UDim2.new(0, 4, 0, 25), 0.3)
        CreateTween(TabIndicator, "BackgroundTransparency", 0, 0.3)
        CreateTween(TabLabel, "TextTransparency", 0, 0.3)
    end
    
    TabButton.MouseButton1Click:Connect(SelectTab)
    
    if FirstTab then
        FirstTab = false
    end
    
    -- ===================================================================
    -- [[ دوال إضافة العناصر ]]
    -- ===================================================================
    local Tab = {}
    
    function Tab:AddSection(name)
        local sectionName = type(name) == "string" and name or name[1] or name.Name or "Section"
        
        local Section = Instance.new("Frame")
        Section.Size = UDim2.new(1, 0, 0, 30)
        Section.BackgroundTransparency = 1
        Section.Parent = Container
        
        local SectionLine = Instance.new("Frame")
        SectionLine.Size = UDim2.new(1, -20, 0, 2)
        SectionLine.Position = UDim2.new(0.5, 0, 1, -2)
        SectionLine.AnchorPoint = Vector2.new(0.5, 0)
        SectionLine.BackgroundColor3 = Color3.fromRGB(218, 165, 32)
        SectionLine.BackgroundTransparency = 0.3
        SectionLine.Parent = Section
        Instance.new("UICorner", SectionLine).CornerRadius = UDim.new(1, 0)
        
        local SectionLabel = Instance.new("TextLabel")
        SectionLabel.Size = UDim2.new(1, -25, 1, 0)
        SectionLabel.Position = UDim2.new(0, 5, 0, 0)
        SectionLabel.BackgroundTransparency = 1
        SectionLabel.Text = sectionName
        SectionLabel.TextColor3 = Color3.fromRGB(255, 215, 0)
        SectionLabel.TextSize = 18
        SectionLabel.Font = Enum.Font.GothamBold
        SectionLabel.TextXAlignment = "Left"
        SectionLabel.Parent = Section
        
        return { Visible = function(_, b) Section.Visible = b end }
    end
    
    function Tab:AddParagraph(config)
        local title = config.Title or config[1] or "Title"
        local text = config.Text or config[2] or ""
        
        local Frame = Instance.new("Frame")
        Frame.Size = UDim2.new(1, 0, 0, 70)
        Frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        Frame.BackgroundTransparency = 0.2
        Frame.Parent = Container
        
        local Corner = Instance.new("UICorner")
        Corner.CornerRadius = UDim.new(0, 10)
        Corner.Parent = Frame
        
        local Stroke = Instance.new("UIStroke")
        Stroke.Color = Color3.fromRGB(218, 165, 32)
        Stroke.Thickness = 1.5
        Stroke.Parent = Frame
        
        local TitleLabel = Instance.new("TextLabel")
        TitleLabel.Size = UDim2.new(1, -20, 0, 25)
        TitleLabel.Position = UDim2.new(0, 10, 0, 10)
        TitleLabel.BackgroundTransparency = 1
        TitleLabel.Text = title
        TitleLabel.TextColor3 = Color3.new(1, 1, 1)
        TitleLabel.TextSize = 16
        TitleLabel.Font = Enum.Font.GothamBold
        TitleLabel.TextXAlignment = "Left"
        TitleLabel.Parent = Frame
        
        local TextLabel = Instance.new("TextLabel")
        TextLabel.Size = UDim2.new(1, -20, 0, 25)
        TextLabel.Position = UDim2.new(0, 10, 0, 40)
        TextLabel.BackgroundTransparency = 1
        TextLabel.Text = text
        TextLabel.TextColor3 = Color3.fromRGB(200, 200, 150)
        TextLabel.TextSize = 12
        TextLabel.Font = Enum.Font.Gotham
        TextLabel.TextXAlignment = "Left"
        TextLabel.TextWrapped = true
        TextLabel.Parent = Frame
        
        return {}
    end
    
    function Tab:AddButton(config)
        local name = config.Name or config[1] or "Button"
        local desc = config.Desc or config.Description or ""
        local callback = config.Callback or function() end
        
        local Frame = Instance.new("Frame")
        Frame.Size = UDim2.new(1, 0, 0, 40)
        Frame.BackgroundTransparency = 1
        Frame.Parent = Container
        
        local Button = Instance.new("TextButton")
        Button.Size = UDim2.new(1, 0, 1, 0)
        Button.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        Button.BackgroundTransparency = 0.2
        Button.AutoButtonColor = false
        Button.Parent = Frame
        Button.Text = ""
        
        local ButtonCorner = Instance.new("UICorner")
        ButtonCorner.CornerRadius = UDim.new(0, 10)
        ButtonCorner.Parent = Button
        
        local ButtonStroke = Instance.new("UIStroke")
        ButtonStroke.Color = Color3.fromRGB(218, 165, 32)
        ButtonStroke.Thickness = 1.5
        ButtonStroke.Parent = Button
        
        local NameLabel = Instance.new("TextLabel")
        NameLabel.Size = UDim2.new(1, -30, 0, 20)
        NameLabel.Position = UDim2.new(0, 10, 0, 5)
        NameLabel.BackgroundTransparency = 1
        NameLabel.Text = name
        NameLabel.TextColor3 = Color3.new(1, 1, 1)
        NameLabel.TextSize = 14
        NameLabel.Font = Enum.Font.GothamBold
        NameLabel.TextXAlignment = "Left"
        NameLabel.Parent = Button
        
        if desc and #desc > 0 then
            local DescLabel = Instance.new("TextLabel")
            DescLabel.Size = UDim2.new(1, -30, 0, 15)
            DescLabel.Position = UDim2.new(0, 10, 0, 22)
            DescLabel.BackgroundTransparency = 1
            DescLabel.Text = desc
            DescLabel.TextColor3 = Color3.fromRGB(200, 200, 150)
            DescLabel.TextSize = 10
            DescLabel.Font = Enum.Font.Gotham
            DescLabel.TextXAlignment = "Left"
            DescLabel.Parent = Button
        end
        
        local Icon = Instance.new("ImageLabel")
        Icon.Size = UDim2.new(0, 16, 0, 16)
        Icon.Position = UDim2.new(1, -15, 0.5)
        Icon.AnchorPoint = Vector2.new(1, 0.5)
        Icon.BackgroundTransparency = 1
        Icon.Image = "rbxassetid://10709791437"
        Icon.ImageColor3 = Color3.fromRGB(255, 215, 0)
        Icon.Parent = Button
        
        Button.MouseButton1Click:Connect(callback)
        
        return {}
    end
    
    return Tab
end

