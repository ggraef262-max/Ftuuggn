local function CreateTween(obj, prop, newVal, time)
    local tween = TweenService:Create(obj, TweenInfo.new(time or 0.3), { [prop] = newVal })
    tween:Play()
    return tween
end

local function MakeDraggable(frame)
    frame.Active = true
    frame.Draggable = true
end

