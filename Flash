-- [[ دالة السحب ]]
-- ===================================================================
local function MakeDrag(Instance)
    Instance.Active = true
    Instance.InputBegan:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 then
            local StartPos, DragStart = Instance.Position, Input.Position
            while UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) do
                RunService.Heartbeat:Wait()
                local delta = Input.Position - DragStart
                Instance.Position = UDim2.new(StartPos.X.Scale, StartPos.X.Offset + delta.X / (ViewportSize.Y/450),
                                             StartPos.Y.Scale, StartPos.Y.Offset + delta.Y / (ViewportSize.Y/450))
            end
        end
    end)
    return Instance
end

