                p.frame.Position = UDim2.fromOffset(pos.X.Offset, pos.Y.Offset + p.direction.Y * 0.016)
                
                if elapsed > ParticleConfig.Lifetime * 0.8 then
                    local fade = 0.3 * (1 - (elapsed - ParticleConfig.Lifetime * 0.8) / (ParticleConfig.Lifetime * 0.2))
                    p.frame.BackgroundTransparency = math.max(1 - fade, 0.9)
                end
            end
        end
    end
    
    local lastSpawn = 0
    local particleConnection = RunService.Heartbeat:Connect(function()
