            speed = speed,
            direction = Vector2.new(0, -speed),
            size = size
        })
    end
    
    local function UpdateParticles()
        for i = #Particles.active, 1, -1 do
            local p = Particles.active[i]
            local elapsed = tick() - p.startTime
            
            if elapsed >= ParticleConfig.Lifetime or p.frame.Position.Y.Offset < -20 then
