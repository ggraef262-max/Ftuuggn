local function LoadConfig()
    if readfile and isfile and isfile("NexusConfig.json") then
        local success, data = pcall(function()
            return HttpService:JSONDecode(readfile("NexusConfig.json"))
        end)
        if success and type(data) == "table" then
            if data.UISize then redzlib.Save.UISize = data.UISize end
            if data.TabSize then redzlib.Save.TabSize = data.TabSize end
            if data.Theme then redzlib.Save.Theme = data.Theme end
        end
    end
end

