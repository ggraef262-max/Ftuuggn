                table.remove(ActiveParticles, i)
            else
                local currentPos = particle.Frame.Position
                local newY = currentPos.Y.Offset + particle.Direction.Y * 0.016
                particle.Frame.Position = UDim2.fromOffset(currentPos.X.Offset, newY)
            end
        end
    end

