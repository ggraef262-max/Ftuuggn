-- ===================================================================
-- [[ دالة تغيير الثيم ]]
-- ===================================================================
function redzlib:SetTheme(NewTheme)
    if not self.Themes[NewTheme] then return end
    self.Save.Theme = NewTheme
    local Theme = self.Themes[NewTheme]
    for _, item in ipairs(self.Instances) do
        if item.Type == "Gradient" then item.Instance.Color = Theme["Color Hub 1"]
        elseif item.Type == "Frame" then item.Instance.BackgroundColor3 = Theme["Color Hub 2"]
        elseif item.Type == "Stroke" then item.Instance.Color = Theme["Color Stroke"]
        elseif item.Type == "Theme" then item.Instance.BackgroundColor3 = Theme["Color Theme"]
        elseif item.Type == "Text" then item.Instance.TextColor3 = Theme["Color Text"]
        elseif item.Type == "DarkText" then item.Instance.TextColor3 = Theme["Color Dark Text"] end
    end
end

