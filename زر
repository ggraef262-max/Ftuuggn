			})
		})
		
		if not FirstTab then
			FirstTab = true
			TabButton.BackgroundColor3 = Theme["Color Theme"]
			Container.Visible = true
		end
		
		TabButton.Activated:Connect(function()
			for _, v in pairs(MainScroll:GetChildren()) do
				if v:IsA("TextButton") then
					v.BackgroundColor3 = Theme["Color Hub 2"]
				end
			end
			for _, v in pairs(Containers:GetChildren()) do
				if v:IsA("ScrollingFrame") then
					v.Visible = false
				end
			end
			TabButton.BackgroundColor3 = Theme["Color Theme"]
			Container.Visible = true
		end)
		
		local TabFunctions = {}
		function TabFunctions:Button(Configs)
			local BTitle = Configs[1] or Configs.Title or "Button"
			local BDesc = Configs[2] or Configs.Description or ""
			local BCallback = Configs[3] or Configs.Callback or function() end
			
			local Button, Label = ButtonFrame(Container, BTitle, BDesc, nil, BCallback)
			return Button
		end
		
		function TabFunctions:Toggle(Configs)
			local TTitle = Configs[1] or Configs.Title or "Toggle"
			local TDesc = Configs[2] or Configs.Description or ""
			local TDefault = Configs[3] or Configs.Default or false
			local TFlag = Configs[4] or Configs.Flag or nil
			local TCallback = Configs[5] or Configs.Callback or function() end
			
			local Frame, Label = ButtonFrame(Container, TTitle, TDesc)
			Frame.Size = UDim2.new(1, 0, 0, 30)
			
			local ToggleButton = InsertTheme(Create("ImageButton", Frame, {
				Size = UDim2.fromOffset(40, 20),
				Position = UDim2.new(1, -10, 0.5),
				AnchorPoint = Vector2.new(1, 0.5),
				BackgroundColor3 = Theme["Color Hub 2"],
				Image = "rbxassetid://10747373176",
				AutoButtonColor = false
			}), "Frame")
			Make("Corner", ToggleButton, UDim.new(0, 10))
			
			local ToggleValue = TDefault
			if TFlag and Flags[TFlag] ~= nil then
				ToggleValue = Flags[TFlag]
			end
			
			local function UpdateToggle()
				if ToggleValue then
					ToggleButton.BackgroundColor3 = Theme["Color Theme"]
					ToggleButton.Image = "rbxassetid://10709790644"
				else
					ToggleButton.BackgroundColor3 = Theme["Color Hub 2"]
					ToggleButton.Image = "rbxassetid://10747384394"
				end
				TCallback(ToggleValue)
				if TFlag then
					SetFlag(TFlag, ToggleValue)
				end
			end
			
			ToggleButton.Activated:Connect(function()
				ToggleValue = not ToggleValue
				UpdateToggle()
			end)
			
			UpdateToggle()
			return Frame, ToggleButton
		end
		
		function TabFunctions:Slider(Configs)
			local STitle = Configs[1] or Configs.Title or "Slider"
			local SDesc = Configs[2] or Configs.Description or ""
			local SMin = Configs[3] or Configs.Min or 0
			local SMax = Configs[4] or Configs.Max or 100
			local SDefault = Configs[5] or Configs.Default or 50
			local SFlag = Configs[6] or Configs.Flag or nil
			local SCallback = Configs[7] or Configs.Callback or function() end
			
			local Frame, Label = ButtonFrame(Container, STitle, SDesc)
			Frame.Size = UDim2.new(1, 0, 0, 50)
			
			local ValueLabel = InsertTheme(Create("TextLabel", Frame, {
				Size = UDim2.fromOffset(40, 20),
				Position = UDim2.new(1, -10, 0.3),
				AnchorPoint = Vector2.new(1, 0.5),
				BackgroundColor3 = Theme["Color Hub 2"],
				Text = tostring(SDefault),
				TextColor3 = Theme["Color Text"],
				TextSize = 10,
				Font = Enum.Font.GothamMedium
			}), "Frame")
			Make("Corner", ValueLabel, UDim.new(0, 5))
			
			local SliderBar = Create("Frame", Frame, {
				Size = UDim2.new(1, -20, 0, 4),
				Position = UDim2.new(0, 10, 0.7),
				BackgroundColor3 = Theme["Color Hub 2"]
			})
			Make("Corner", SliderBar, UDim.new(0, 2))
			
			local SliderFill = Create("Frame", SliderBar, {
				Size = UDim2.new((SDefault - SMin) / (SMax - SMin), 0, 1, 0),
				BackgroundColor3 = Theme["Color Theme"]
			})
			Make("Corner", SliderFill, UDim.new(0, 2))
			
			local SliderButton = Create("ImageButton", SliderFill, {
				Size = UDim2.fromOffset(12, 12),
				Position = UDim2.new(1, -6, 0.5),
				AnchorPoint = Vector2.new(0.5, 0.5),
				BackgroundColor3 = Theme["Color Theme"],
				Image = "rbxassetid://10709797837"
			})
			Make("Corner", SliderButton, UDim.new(0, 6))
			
			local SliderValue = SDefault
			if SFlag and Flags[SFlag] ~= nil then
				SliderValue = Flags[SFlag]
				ValueLabel.Text = tostring(SliderValue)
				SliderFill.Size = UDim2.new((SliderValue - SMin) / (SMax - SMin), 0, 1, 0)
			end
			
			local function UpdateSlider(Value)
				SliderValue = math.clamp(Value, SMin, SMax)
				ValueLabel.Text = tostring(math.floor(SliderValue))
				SliderFill.Size = UDim2.new((SliderValue - SMin) / (SMax - SMin), 0, 1, 0)
				SCallback(SliderValue)
				if SFlag then
					SetFlag(SFlag, SliderValue)
				end
			end
			
			SliderButton.InputBegan:Connect(function(Input)
				if Input.UserInputType == Enum.UserInputType.MouseButton1 then
					while UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) do
						local MousePos = UserInputService:GetMouseLocation()
						local BarPos = SliderBar.AbsolutePosition.X
						local BarSize = SliderBar.AbsoluteSize.X
						local Percent = (MousePos.X - BarPos) / BarSize
						local Value = SMin + (Percent * (SMax - SMin))
						UpdateSlider(Value)
						task.wait()
					end
				end
			end)
			
			UpdateSlider(SliderValue)
			return Frame, SliderButton
		end
		
		function TabFunctions:Dropdown(Configs)
			local DTitle = Configs[1] or Configs.Title or "Dropdown"
			local DDesc = Configs[2] or Configs.Description or ""
			local DOptions = Configs[3] or Configs.Options or {}
			local DDefault = Configs[4] or Configs.Default or nil
			local DFlag = Configs[5] or Configs.Flag or nil
			local DCallback = Configs[6] or Configs.Callback or function() end
			
			local Frame, Label = ButtonFrame(Container, DTitle, DDesc)
			Frame.Size = UDim2.new(1, 0, 0, 45)
			
			local DropdownButton = InsertTheme(Create("ImageButton", Frame, {
				Size = UDim2.new(0, 120, 0, 25),
				Position = UDim2.new(1, -10, 0.5),
				AnchorPoint = Vector2.new(1, 0.5),
				BackgroundColor3 = Theme["Color Hub 2"],
				AutoButtonColor = false
			}), "Frame")
			Make("Corner", DropdownButton, UDim.new(0, 5))
			
			local DropdownText = InsertTheme(Create("TextLabel", DropdownButton, {
				Size = UDim2.new(1, -5, 1, 0),
				Position = UDim2.new(0, 5, 0.5),
				AnchorPoint = Vector2.new(0, 0.5),
				BackgroundTransparency = 1,
				Text = DDefault or DOptions[1] or "Select",
				TextXAlignment = "Left",
				TextColor3 = Theme["Color Text"],
				TextSize = 10
			}), "Text")
			
			local DropdownArrow = Create("ImageLabel", DropdownButton, {
				Size = UDim2.fromOffset(12, 12),
				Position = UDim2.new(1, -5, 0.5),
				AnchorPoint = Vector2.new(1, 0.5),
				BackgroundTransparency = 1,
				Image = "rbxassetid://10709791523"
			})
			
			local DropdownFrame = Create("Frame", DropdownHolder, {
				Size = UDim2.fromOffset(120, 0),
				BackgroundColor3 = Theme["Color Hub 2"],
				ClipsDescendants = true,
				Visible = false
			})
			Make("Corner", DropdownFrame, UDim.new(0, 5))
			Make("Stroke", DropdownFrame)
			
			local DropdownList = Create("ScrollingFrame", DropdownFrame, {
				Size = UDim2.new(1, 0, 1, 0),
				BackgroundTransparency = 1,
				ScrollBarThickness = 2,
				CanvasSize = UDim2.new(),
				AutomaticCanvasSize = "Y"
			}, {
				Create("UIListLayout", {
					Padding = UDim.new(0, 2)
				})
			})
			
			local DropdownValue = DDefault or DOptions[1]
			
			local function UpdateDropdown(Value)
				DropdownValue = Value
				DropdownText.Text = Value
				DCallback(Value)
				if DFlag then
					SetFlag(DFlag, Value)
				end
				DropdownFrame.Visible = false
			end
			
			for _, Option in ipairs(DOptions) do
				local OptionButton = Make("Button", DropdownList, {
					Size = UDim2.new(1, -10, 0, 25),
					BackgroundColor3 = Theme["Color Hub 2"],
					AutomaticSize = "Y"
				})
				Make("Corner", OptionButton, UDim.new(0, 4))
				
				local OptionText = InsertTheme(Create("TextLabel", OptionButton, {
					Size = UDim2.new(1, -10, 1, 0),
					Position = UDim2.new(0, 5, 0.5),
					AnchorPoint = Vector2.new(0, 0.5),
					BackgroundTransparency = 1,
					Text = Option,
					TextXAlignment = "Left",
					TextColor3 = Theme["Color Text"],
					TextSize = 10
				}), "Text")
				
				OptionButton.Activated:Connect(function()
					UpdateDropdown(Option)
				end)
			end
			
			DropdownButton.Activated:Connect(function()
				DropdownFrame.Visible = not DropdownFrame.Visible
				if DropdownFrame.Visible then
					local AbsPos = DropdownButton.AbsolutePosition
					DropdownFrame.Position = UDim2.new(0, AbsPos.X, 0, AbsPos.Y + 30)
					DropdownFrame.Size = UDim2.fromOffset(120, math.min(150, #DOptions * 28))
				end
			end)
			
			if DFlag and Flags[DFlag] then
				UpdateDropdown(Flags[DFlag])
			elseif DDefault then
				UpdateDropdown(DDefault)
			end
			
			return Frame, DropdownButton
		end
		
		return TabFunctions
	end
	
	return WindowFunctions
end

return redzlib
