	local WindowFunctions = {}
	function WindowFunctions:Tab(TabName, TabIcon)
		local TabButton = InsertTheme(Create("TextButton", MainScroll, {
			Size = UDim2.new(1, 0, 0, 30),
			Text = "  " .. TabName,
			TextXAlignment = "Left",
			TextColor3 = Theme["Color Text"],
			BackgroundColor3 = Theme["Color Hub 2"],
			Font = Enum.Font.Gotham,
			TextSize = 12,
			AutoButtonColor = false,
			Name = TabName
		}), "Frame")
		Make("Corner", TabButton)
		
		if TabIcon then
			local Icon = Create("ImageLabel", TabButton, {
				Size = UDim2.fromOffset(16, 16),
				Position = UDim2.fromOffset(8, 7),
				BackgroundTransparency = 1,
				Image = redzlib:GetIcon(TabIcon),
				ImageColor3 = Theme["Color Text"]
			})
		end
		
		local Container = Create("ScrollingFrame", Containers, {
			Size = UDim2.new(1, -15, 1, -10),
			Position = UDim2.new(0, 0, 0, 5),
			BackgroundTransparency = 1,
			ScrollBarThickness = 3,
			ScrollBarImageColor3 = Theme["Color Theme"],
			CanvasSize = UDim2.new(),
			AutomaticCanvasSize = "Y",
			ScrollingDirection = "Y",
			BorderSizePixel = 0,
			Visible = false,
			Name = TabName
		}, {
			Create("UIPadding", {
				PaddingLeft = UDim.new(0, 10),
				PaddingRight = UDim.new(0, 10),
				PaddingTop = UDim.new(0, 5),
