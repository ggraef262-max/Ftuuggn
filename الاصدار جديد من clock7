local chatActive = {}

local function sendChatMessage(msg)
    if TextChatService.ChatVersion ~= Enum.ChatVersion.LegacyChatService then
        TextChatService.ChatInputBarConfiguration.TargetTextChannel:SendAsync(msg)
    else
        local chatRemote = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents")
        if chatRemote then
            local sayMsg = chatRemote:FindFirstChild("SayMessageRequest")
            if sayMsg then
                sayMsg:FireServer(msg, "All")
            end
        end
    end
end

for i, speed in ipairs(chatSpeeds) do
    local sectionName = "سرعة " .. tostring(speed) .. " ثانية"
    chatTab:AddSection({ sectionName })
    
    local msgVar = nil
    
    chatTab:AddTextBox({
        Name = "النص المرسل",
        Description = "أدخل النص الذي تريد إرساله",
        Default = "",
        PlaceholderText = "اكتب النص هنا",
        ClearText = true,
        Callback = function(value)
            msgVar = value
        end
    })
    
    chatTab:AddToggle({
        Name = "تشغيل الإرسال",
        Description = "بدء إرسال النص بشكل متكرر",
        Default = false,
        Flag = "chat_toggle_" .. i,
        Callback = function(value)
            chatActive[i] = value
            
            if value and msgVar then
                coroutine.wrap(function()
                    while chatActive[i] do
                        sendChatMessage(msgVar)
                        wait(speed)
                    end
                end)()
            end
        end
    })
end

