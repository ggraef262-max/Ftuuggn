            if noclipConn then
                noclipConn:Disconnect()
                noclipConn = nil
            end
            local char = getCharacter()
            if char then
                setCollision(char, true)
            end
            sendNotification("نو كليب", "تم الإيقاف", nil, 2)
        end
    end
})

