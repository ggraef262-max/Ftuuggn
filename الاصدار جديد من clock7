local function createIntro()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "IntroStarsGui"
    screenGui.IgnoreGuiInset = true
    screenGui.ResetOnSpawn = false
    screenGui.Parent = PlayerGui

    local darkFrame = Instance.new("Frame")
    darkFrame.Size = UDim2.new(1, 0, 1, 0)
    darkFrame.BackgroundColor3 = Color3.new(0, 0, 0)
    darkFrame.BackgroundTransparency = 0.6
    darkFrame.BorderSizePixel = 0
    darkFrame.Parent = screenGui

    -- صورة النجمة المصححة
    local starImage = Instance.new("ImageLabel")
    starImage.Size = UDim2.new(0, 170, 0, 170)
    starImage.Position = UDim2.new(0.5, 0, 0.35, 0)
    starImage.AnchorPoint = Vector2.new(0.5, 0.5)
    starImage.BackgroundTransparency = 1
    starImage.Image = "rbxassetid://90798133906684" -- رابط نجمة صحيح
    starImage.ImageColor3 = Color3.fromRGB(147, 112, 219)
    starImage.ImageTransparency = 0.7
    starImage.Parent = screenGui

    -- صورة اللوجو المصححة
    local logoImage = Instance.new("ImageLabel")
    logoImage.Size = UDim2.new(0, 150, 0, 150)
    logoImage.Position = UDim2.new(0.5, 0, 0.35, 0)
    logoImage.AnchorPoint = Vector2.new(0.5, 0.5)
    logoImage.BackgroundTransparency = 1
    logoImage.Image = "rbxassetid://90798133906684" -- صورة افتراضية مؤقتة
    logoImage.Parent = screenGui

    local titleLabel = Instance.new("TextLabel")
    titleLabel.Size = UDim2.new(0.6, 0, 0.07, 0)
    titleLabel.Position = UDim2.new(-0.6, 0, 0.58, 0)
    titleLabel.AnchorPoint = Vector2.new(0.5, 0)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Text = "منتظر Clock7 RP"
    titleLabel.TextColor3 = Color3.fromRGB(147, 112, 219)
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextScaled = true
    titleLabel.Parent = screenGui

    local progressBarFrame = Instance.new("Frame")
    progressBarFrame.Size = UDim2.new(0.45, 0, 0.04, 0)
    progressBarFrame.Position = UDim2.new(0.5, 0, 0.68, 0)
    progressBarFrame.AnchorPoint = Vector2.new(0.5, 0)
    progressBarFrame.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    progressBarFrame.BackgroundTransparency = 0.4
    progressBarFrame.BorderSizePixel = 0
    progressBarFrame.ClipsDescendants = true
    progressBarFrame.Parent = screenGui

    local progressBarCorner = Instance.new("UICorner")
    progressBarCorner.CornerRadius = UDim.new(0, 12)
    progressBarCorner.Parent = progressBarFrame

    local progressFill = Instance.new("Frame")
    progressFill.Size = UDim2.new(0, 0, 1, 0)
    progressFill.Position = UDim2.new(0, 0, 0, 0)
    progressFill.BackgroundColor3 = Color3.fromRGB(0, 191, 255)
    progressFill.BorderSizePixel = 0
    progressFill.Parent = progressBarFrame

    local progressFillCorner = Instance.new("UICorner")
    progressFillCorner.CornerRadius = UDim.new(0, 12)
    progressFillCorner.Parent = progressFill

    local shineEffect = Instance.new("Frame")
    shineEffect.Size = UDim2.new(0.2, 0, 1, 0)
    shineEffect.Position = UDim2.new(-0.2, 0, 0, 0)
    shineEffect.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    shineEffect.BackgroundTransparency = 0.8
    shineEffect.BorderSizePixel = 0
    shineEffect.Parent = progressBarFrame

    local shineCorner = Instance.new("UICorner")
    shineCorner.CornerRadius = UDim.new(0, 12)
    shineCorner.Parent = shineEffect

    TweenService:Create(titleLabel, TweenInfo.new(1.5, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
        Position = UDim2.new(0.5, 0, 0.58, 0)
    }):Play()

    TweenService:Create(starImage, TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
        ImageTransparency = 0.3
    }):Play()

    local progressTween = TweenService:Create(progressFill, TweenInfo.new(5, Enum.EasingStyle.Linear), {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = Color3.fromRGB(147, 112, 219)
    })
    progressTween:Play()

    coroutine.wrap(function()
        while true do
            local shineTween = TweenService:Create(shineEffect, TweenInfo.new(2, Enum.EasingStyle.Linear), {
                Position = UDim2.new(1, 0, 0, 0)
            })
            shineTween:Play()
            shineTween.Completed:Wait()
            shineEffect.Position = UDim2.new(-0.2, 0, 0, 0)
        end
    end)()

    local isIntroActive = true
    coroutine.wrap(function()
        while isIntroActive do
            local star = Instance.new("Frame")
            local size = math.random(2, 3)
            star.Size = UDim2.new(0, size, 0, size)
            star.Position = UDim2.new(math.random(), 0, 0, -10)
            star.BackgroundColor3 = Color3.new(1, 1, 1)
            star.BorderSizePixel = 0
            star.BackgroundTransparency = 0
            star.AnchorPoint = Vector2.new(0.5, 0.5)
            star.Parent = darkFrame

            TweenService:Create(star, TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                BackgroundTransparency = 0.6
            }):Play()

            local rotationAngle = 0
            local rotationConnection = RunService.RenderStepped:Connect(function(delta)
                rotationAngle = rotationAngle + 60 * delta
                star.Rotation = rotationAngle
                if not star.Parent then
                    rotationConnection:Disconnect()
                end
            end)

            local fallTime = math.random(2, 4)
            local fallTween = TweenService:Create(star, TweenInfo.new(fallTime, Enum.EasingStyle.Linear), {
                Position = UDim2.new(star.Position.X.Scale, 0, 1, 10)
            })
            fallTween:Play()
            fallTween.Completed:Connect(function()
                star:Destroy()
            end)

            wait(0.02)
        end
    end)()

    progressTween.Completed:Wait()
    isIntroActive = false

    local fadeOutElements = {darkFrame, starImage, logoImage, titleLabel, progressBarFrame, progressFill, shineEffect}
    for _, element in ipairs(fadeOutElements) do
        local fadeInfo = TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        local fadeProps = {}
        
        if element.BackgroundTransparency ~= nil then
            fadeProps.BackgroundTransparency = 1
        end
        if element:IsA("TextLabel") then
            fadeProps.TextTransparency = 1
        end
        if element:IsA("ImageLabel") then
            fadeProps.ImageTransparency = 1
        end
        
        local fadeTween = TweenService:Create(element, fadeInfo, fadeProps)
        fadeTween:Play()
        fadeTween.Completed:Wait()
    end

    screenGui:Destroy()
end

local success, err = pcall(createIntro)
if not success then
