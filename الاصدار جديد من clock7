            CurrentCamera.CameraSubject = getHumanoid()
            sendNotification("مشاهدة", "تم إيقاف المشاهدة", nil, 2)
            return
        end
        
        for _, player in ipairs(Players:GetPlayers()) do
            if player.Name:lower():find(value:lower(), 1, true) or 
               (player.DisplayName and player.DisplayName:lower():find(value:lower(), 1, true)) then
                spectateTarget = player
                break
            end
        end
        
        if spectateTarget then
            if spectateConn then
                spectateConn:Disconnect()
            end
            
            spectateConn = RunService.Heartbeat:Connect(function()
                if spectateTarget and spectateTarget.Character then
                    local hum = spectateTarget.Character:FindFirstChildOfClass("Humanoid")
                    if hum then
                        CurrentCamera.CameraSubject = hum
                    end
                end
            end)
            
            sendNotification("مشاهدة", "جاري مشاهدة " .. spectateTarget.Name, nil, 2)
        else
            sendNotification("خطأ", "لم يتم العثور على اللاعب", nil, 3)
        end
    end
})

-- Noclip
local noclipConn = nil

local function setCollision(obj, state)
    for _, descendant in ipairs(obj:GetDescendants()) do
        if descendant:IsA("BasePart") then
            descendant.CanCollide = state
        end
    end
end

