end

function AddButton(parent, text, callback)
    local btn = Create("TextButton", parent, {
        Size = UDim2.new(1, 0, 0, 45),
        BackgroundColor3 = Colors.Second,
        Text = ""
    })
    AddCorner(btn, 12)
    AddStroke(btn, Colors.Main, 1)
    
    local txt = Create("TextLabel", btn, {
        Size = UDim2.new(1, -20, 1, 0),
        Position = UDim2.new(0, 10, 0, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = Colors.Text,
        TextXAlignment = "Left",
        Font = Enum.Font.Gotham,
        TextSize = 16
    })
    
    btn.MouseButton1Click:Connect(callback)
    
    btn.MouseEnter:Connect(function()
        Tween(btn, "BackgroundColor3", Colors.Main, 0.2)
    end)
    
    btn.MouseLeave:Connect(function()
        Tween(btn, "BackgroundColor3", Colors.Second, 0.2)
    end)
    
    return btn
end

function AddToggle(parent, text, default, callback)
    local frame = Create("Frame", parent, {
        Size = UDim2.new(1, 0, 0, 45),
        BackgroundColor3 = Colors.Second
    })
    AddCorner(frame, 12)
    AddStroke(frame, Colors.Main, 1)
    
    local label = Create("TextLabel", frame, {
        Size = UDim2.new(0.7, -15, 1, 0),
        Position = UDim2.new(0, 10, 0, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = Colors.Text,
        TextXAlignment = "Left",
        Font = Enum.Font.Gotham,
        TextSize = 16
    })
    
    local toggle = Create("TextButton", frame, {
        Size = UDim2.new(0, 70, 0, 30),
        Position = UDim2.new(1, -80, 0.5, -15),
        BackgroundColor3 = default and Colors.Main or Colors.Background,
        Text = default and "ON" or "OFF",
        TextColor3 = Colors.Text,
        Font = Enum.Font.GothamBold,
        TextSize = 14
    })
    AddCorner(toggle, 20)
    
    local state = default
    
    toggle.MouseButton1Click:Connect(function()
        state = not state
        Tween(toggle, "BackgroundColor3", state and Colors.Main or Colors.Background, 0.2)
        toggle.Text = state and "ON" or "OFF"
        callback(state)
    end)
    
    return frame
end

function AddSlider(parent, text, min, max, default, callback)
    local frame = Create("Frame", parent, {
        Size = UDim2.new(1, 0, 0, 60),
        BackgroundColor3 = Colors.Second
    })
    AddCorner(frame, 12)
    AddStroke(frame, Colors.Main, 1)
    
    local label = Create("TextLabel", frame, {
        Size = UDim2.new(0.6, -10, 0, 20),
        Position = UDim2.new(0, 10, 0, 5),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = Colors.Text,
        TextXAlignment = "Left",
        Font = Enum.Font.Gotham,
        TextSize = 14
    })
    
    local valueLabel = Create("TextLabel", frame, {
        Size = UDim2.new(0.3, -5, 0, 20),
        Position = UDim2.new(0.7, 0, 0, 5),
        BackgroundTransparency = 1,
        Text = tostring(default),
        TextColor3 = Colors.Main,
        TextXAlignment = "Right",
        Font = Enum.Font.GothamBold,
        TextSize = 16
    })
    
    local bar = Create("Frame", frame, {
        Size = UDim2.new(1, -20, 0, 20),
        Position = UDim2.new(0, 10, 0, 30),
        BackgroundColor3 = Colors.Background
    })
    AddCorner(bar, 10)
    
    local fill = Create("Frame", bar, {
        Size = UDim2.new((default - min) / (max - min), 0, 1, 0),
        BackgroundColor3 = Colors.Main
    })
    AddCorner(fill, 10)
    
    local drag = Create("TextButton", bar, {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = ""
    })
    
    local dragging = false
    
    drag.MouseButton1Down:Connect(function()
        dragging = true
    end)
    
    game:GetService("UserInputService").InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    game:GetService("RunService").Heartbeat:Connect(function()
        if dragging then
            local mouse = game:GetService("Players").LocalPlayer:GetMouse()
            local pos = mouse.X - bar.AbsolutePosition.X
            local percent = math.clamp(pos / bar.AbsoluteSize.X, 0, 1)
            local val = math.floor(min + (max - min) * percent)
            fill.Size = UDim2.new(percent, 0, 1, 0)
            valueLabel.Text = tostring(val)
            callback(val)
        end
    end)
    
    return frame
end

function AddDropdown(parent, text, options, default, callback)
    local frame = Create("Frame", parent, {
        Size = UDim2.new(1, 0, 0, 70),
        BackgroundColor3 = Colors.Second
    })
    AddCorner(frame, 12)
    AddStroke(frame, Colors.Main, 1)
    
    local label = Create("TextLabel", frame, {
        Size = UDim2.new(1, -20, 0, 20),
        Position = UDim2.new(0, 10, 0, 5),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = Colors.Text,
        TextXAlignment = "Left",
        Font = Enum.Font.Gotham,
        TextSize = 14
    })
    
    local dropdown = Create("TextButton", frame, {
        Size = UDim2.new(1, -20, 0, 30),
        Position = UDim2.new(0, 10, 0, 30),
        BackgroundColor3 = Colors.Background,
        Text = default or options[1] or "",
        TextColor3 = Colors.Text,
        Font = Enum.Font.Gotham,
        TextSize = 14
    })
    AddCorner(dropdown, 10)
    
    local arrow = Create("TextLabel", dropdown, {
        Size = UDim2.new(0, 20, 1, 0),
        Position = UDim2.new(1, -25, 0, 0),
        BackgroundTransparency = 1,
        Text = "▼",
        TextColor3 = Colors.Main,
        Font = Enum.Font.GothamBold,
        TextSize = 12
    })
    
    dropdown.MouseButton1Click:Connect(function()
        local current = dropdown.Text
        local idx = 1
        for i, opt in ipairs(options) do
            if opt == current then
                idx = i + 1
                break
            end
        end
        if idx > #options then idx = 1 end
        dropdown.Text = options[idx]
        callback(options[idx])
    end)
    
    return frame
end

function AddLabel(parent, text, size)
    local label = Create("TextLabel", parent, {
        Size = UDim2.new(1, -10, 0, 25),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = Colors.Text,
        TextXAlignment = "Left",
        Font = Enum.Font.Gotham,
        TextSize = size or 14
    })
    return label
end

