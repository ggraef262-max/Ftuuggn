local Tabs = {}
local CurrentTab = nil

function MakeTab(name, isActive)
    local btn = Create("TextButton", SideBar, {
        Size = UDim2.new(1, -10, 0, 45),
        Position = UDim2.new(0, 5, 0, 5 + (#Tabs * 50)),
        BackgroundColor3 = isActive and Colors.Main or Colors.Background,
        Text = ""
    })
    AddCorner(btn, 12)
    AddStroke(btn, Colors.Main, 1)
    
    local txt = Create("TextLabel", btn, {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = Colors.Text,
        Font = Enum.Font.Gotham,
        TextSize = 16
    })
    
    local content = Create("Frame", Scroll, {
        Size = UDim2.new(1, 0, 0, 0),
        BackgroundTransparency = 1,
        Visible = isActive or false
    })
    
    local contentLayout = Create("UIListLayout", content, {
        Padding = UDim.new(0, 10),
        HorizontalAlignment = "Center"
    })
    
    local tab = {
        Btn = btn,
        Content = content,
        Layout = contentLayout,
        Name = name
    }
    table.insert(Tabs, tab)
    
    btn.MouseButton1Click:Connect(function()
        for _, t in ipairs(Tabs) do
            t.Btn.BackgroundColor3 = Colors.Background
            t.Content.Visible = false
        end
        btn.BackgroundColor3 = Colors.Main
        content.Visible = true
        CurrentTab = content
    end)
    
    return content
end

