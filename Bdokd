--[====[
    Table to store backups of items (vehicles, canoes, jets, balls).
    Idea: Before deleting an item that doesn't belong to us, we save a copy of it, so we can restore it
    later when the protection feature is turned off.
    This prevents losing other items in the server permanently.
]====]
local backupTables = {
    Vehicles = {},   -- For cars
    Canoes = {},     -- For canoes (regular boats)
    Jets = {},       -- For jets
    Helis = {},      -- For helicopters
    Balls = {}       -- For soccer balls
}

local TeleportCarro = {}
function TeleportCarro:MostrarNotificacao(msg)
    print("🔒 "..msg) -- Print message in Console instead of in-game notification
end

--[====[
    Core helper function: Creates a loop that runs repeatedly.
    This function is the heart of all Anti-Fling features.
    Function: Continuously searches for specific items (like canoes, jets) in their folders.
    If it finds an item that does not belong to the player (i.e., an item that could be used to Fling you),
    it deletes it to prevent the danger, but before deletion, it saves a copy in `backupTables`.
    - name: The type of item name (for storage in the backup table).
    - getFolderFunc: A function that returns the folder where these items are located.
]====]
local function AntiFlingLoop(name, getFolderFunc)
    local active = false
    task.spawn(function()
        while true do
            if active and LocalPlayer.Character then
                local folder = getFolderFunc()
                if folder then
                    for _, item in ipairs(folder:GetChildren()) do
                        local isMine = false
                        -- Check if the item belongs to the local player
                        if name == "Vehicles" then
                            -- For cars: check if any seat in the car is occupied by the local player
                            for _, seat in ipairs(item:GetDescendants()) do
                                if (seat:IsA("VehicleSeat") or seat:IsA("Seat")) and seat.Occupant and seat.Occupant.Parent == LocalPlayer.Character then
                                    isMine = true
                                    break
                                end
                            end
                        elseif name == "Canoes" then
                            -- For canoes: check for a Value named 'Owner' with the value equal to the player
                            local owner = item:FindFirstChild("Owner")
                            isMine = owner and owner.Value == LocalPlayer
                        elseif name == "Jets" or name == "Helis" then
                            -- For aircraft: the item's name itself is usually the player's name
                            isMine = item.Name == LocalPlayer.Name
                        end
                        
                        -- If the item does not belong to us, delete it after saving a copy
                        if not isMine then
                            table.insert(backupTables[name], item:Clone())
                            item:Destroy()
                        end
                    end
                end
            end
            task.wait(0.03) -- Wait 0.03 seconds before repeating the loop (high speed)
        end
    end)
    -- This function returns another function that is called when the toggle is turned on/off
    return function(state)
        active = state
        TeleportCarro:MostrarNotificacao(name.." "..(state and "Activated!" or "Deactivated!"))
        if not state then
            -- When deactivating, restore all previously deleted items
            for _, item in ipairs(backupTables[name]) do
                local parentFolder = getFolderFunc()
                if parentFolder then 
                    item.Parent = parentFolder 
                end
            end
            backupTables[name] = {} -- Clear the backup table after restoration
        end
    end
end

