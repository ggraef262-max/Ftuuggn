-- ======================
local function safeFind(parent, name, waitTime)
    if waitTime then
        return parent:WaitForChild(name, waitTime)
    end
    return parent:FindFirstChild(name)
end

local function safeGetRemote(path)
    local remote = ReplicatedStorage
    for _, name in ipairs(path) do
        remote = remote:FindFirstChild(name)
        if not remote then return nil end
    end
    return remote
end

local function fireRemote(path, ...)
    local remote = safeGetRemote(path)
    if remote then
        remote:FireServer(...)
    end
end

local function invokeRemote(path, ...)
    local remote = safeGetRemote(path)
    if remote then
        return remote:InvokeServer(...)
    end
    return nil
end

local function sendNotification(title, text, icon, duration)
    StarterGui:SetCore("SendNotification", {
        Title = tostring(title),
        Text = tostring(text),
        Icon = icon or "rbxassetid://" .. IMAGE_ID,
        Duration = duration or 5
    })
end

local function getCharacter()
    return LocalPlayer.Character
end

local function getRootPart()
    local char = getCharacter()
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid()
    local char = getCharacter()
    return char and char:FindFirstChildOfClass("Humanoid")
end

