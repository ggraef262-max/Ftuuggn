--[[
    clock7
]]

repeat wait() until game:IsLoaded()

local TeleportTime = 0.05
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local localPlayer = Players.LocalPlayer

local toggle = false
local targetPos = Vector3.new(905, -500, 0)
local lastPos
local velConn

repeat wait() until localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")
local character = localPlayer.Character
local hrp = character:FindFirstChild("HumanoidRootPart")

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "clock7"
ScreenGui.ResetOnSpawn = false
ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
ScreenGui.Parent = localPlayer:WaitForChild("PlayerGui")

local MainFrame = Instance.new("Frame")
MainFrame.Size = UDim2.new(0, 180, 0, 60)
MainFrame.Position = UDim2.new(0.02, 0, 0.3, 0)
MainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
MainFrame.BackgroundTransparency = 0.1
MainFrame.BorderSizePixel = 2
MainFrame.BorderColor3 = Color3.fromRGB(0, 200, 255)
MainFrame.Active = true
MainFrame.Draggable = true
MainFrame.Parent = ScreenGui

local ToggleBtn = Instance.new("TextButton")
ToggleBtn.Size = UDim2.new(1, -10, 1, -10)
ToggleBtn.Position = UDim2.new(0, 5, 0, 5)
ToggleBtn.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
ToggleBtn.Text = "clock7: OFF"
ToggleBtn.TextColor3 = Color3.new(1, 1, 1)
ToggleBtn.TextScaled = true
ToggleBtn.Font = Enum.Font.GothamBold
ToggleBtn.Parent = MainFrame

local function resetCamera()
    if workspace.CurrentCamera and localPlayer.Character then
        local humanoid = localPlayer.Character:FindFirstChildWhichIsA("Humanoid")
        if humanoid then
            workspace.CurrentCamera.CameraSubject = humanoid
        end
    end
end

local function stopVel()
    if velConn then
        velConn:Disconnect()
        velConn = nil
    end
end

local function toggleGaze()
    if not localPlayer.Character then return end
    
    local hrp = localPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    if toggle then
        toggle = false
        ToggleBtn.Text = "clock7: OFF"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
        stopVel()
        
        if lastPos then
            hrp.CFrame = CFrame.new(lastPos)
        end
        
        workspace.FallenPartsDestroyHeight = -500
        resetCamera()
        
        if workspace:FindFirstChild("clock7Point") then
            workspace.clock7Point:Destroy()
        end
        
        hrp.Anchored = false
        
    else
        lastPos = hrp.Position
        
        local gazePart = Instance.new("Part")
        gazePart.Size = Vector3.new(3, 1, 3)
        gazePart.Position = lastPos
        gazePart.Anchored = true
        gazePart.CanCollide = false
        gazePart.Transparency = 0.3
        gazePart.BrickColor = BrickColor.new("Bright red")
        gazePart.Name = "clock7Point"
        gazePart.Parent = workspace
        
        workspace.CurrentCamera.CameraSubject = gazePart
        
        toggle = true
        ToggleBtn.Text = "clock7: ON"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(50, 255, 50)
        
        wait(0.1)
        workspace.FallenPartsDestroyHeight = -1000
        
        hrp.CFrame = CFrame.new(targetPos)
        wait(TeleportTime)
        
        hrp.Anchored = true
        
        velConn = RunService.Heartbeat:Connect(function()
            if toggle and localPlayer.Character then
                local root = localPlayer.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    root.Velocity = Vector3.new(0, 0, 0)
                    root.Anchored = true
                end
            end
        end)
    end
end

ToggleBtn.MouseButton1Click:Connect(toggleGaze)

UserInputService.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.G and not UserInputService:GetFocusedTextBox() then
        toggleGaze()
    end
end)

localPlayer.CharacterAdded:Connect(function(char)
    wait(1)
    character = char
    hrp = char:WaitForChild("HumanoidRootPart")
    if toggle then
        toggle = false
        toggleGaze()
    end
end)

print("✅ clock7 loaded")
print("🔥 Press G to toggle")
