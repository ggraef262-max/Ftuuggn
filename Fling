-- متغيرات
local lastPositions = setmetatable({}, {__mode = "k"})
local range = 25
local overlapParams = OverlapParams.new()
overlapParams.FilterType = Enum.RaycastFilterType.Exclude

local AntiFling = true
local RemoveFall = false
local GazeActive = false
local gazeConnection
local targetPos = Vector3.new(905, -500, 0)
local lastCharPos

-- ===== AntiFling =====
local function setupCharacter(char)
    if not char then return end
    overlapParams.FilterDescendantsInstances = {char}
    lastPositions = setmetatable({}, {__mode = "k"})
    print("[clock7] Character updated")
end

setupCharacter(player.Character)
player.CharacterAdded:Connect(function(char)
    wait(1)
    setupCharacter(char)
end)

-- AntiFling loop
RunService.Heartbeat:Connect(function()
    if not AntiFling then return end
    
    local char = player.Character
    if not char or not char.Parent then return end
    
    overlapParams.FilterDescendantsInstances = {char}
    
    local cf, size = char:GetBoundingBox()
    local regionSize = size + Vector3.new(range, range, range)
    local ok, parts = pcall(function()
        return workspace:GetPartBoundsInBox(cf, regionSize, overlapParams)
    end)
    
    if ok and parts then
        for _, part in ipairs(parts) do
            pcall(function()
                part.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                part.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                part.Velocity = Vector3.new(0, 0, 0)
                part.RotVelocity = Vector3.new(0, 0, 0)
                
                local lastPos = lastPositions[part]
                if lastPos and (part.Position - lastPos).Magnitude > 1.5 then
                    part.CanCollide = false
                end
                lastPositions[part] = part.Position
            end)
        end
    end
end)

-- ===== RemoveFall =====
local function getRoot(char)
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function startRemoveFall()
    task.spawn(function()
        while RemoveFall do
            RunService.Heartbeat:Wait()
            local char = player.Character
            local root = getRoot(char)
            
            if char and root and root.Parent then
                local vel = root.Velocity
                pcall(function() root.Velocity = Vector3.new(0, 0, 0) end)
                
                RunService.RenderStepped:Wait()
                if root and root.Parent then
                    pcall(function() root.Velocity = vel end)
                end
            end
        end
    end)
end

-- ===== Gaze System =====
local function toggleGaze()
    if not player.Character then return end
    
    local hrp = player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    if GazeActive then
        GazeActive = false
        GazeBtn.Text = "🎯 Gaze: OFF"
        GazeBtn.BackgroundColor3 = Color3.fromRGB(255, 100, 0)
        
        if gazeConnection then
            gazeConnection:Disconnect()
            gazeConnection = nil
        end
        
        if lastCharPos then
            hrp.CFrame = CFrame.new(lastCharPos)
        end
        
        workspace.FallenPartsDestroyHeight = -500
        
        if workspace.CurrentCamera and player.Character then
            local humanoid = player.Character:FindFirstChildWhichIsA("Humanoid")
            if humanoid then
                workspace.CurrentCamera.CameraSubject = humanoid
            end
        end
        
        if workspace:FindFirstChild("GazePoint7") then
            workspace.GazePoint7:Destroy()
        end
        
        hrp.Anchored = false
        
    else
        lastCharPos = hrp.Position
        
        local gazePart = Instance.new("Part")
        gazePart.Size = Vector3.new(4, 1, 4)
        gazePart.Position = lastCharPos
        gazePart.Anchored = true
        gazePart.CanCollide = false
        gazePart.Transparency = 0.4
        gazePart.BrickColor = BrickColor.new("Bright blue")
        gazePart.Material = Enum.Material.Neon
        gazePart.Name = "GazePoint7"
        gazePart.Parent = workspace
        
        local pointLight = Instance.new("PointLight")
        pointLight.Color = Color3.fromRGB(0, 150, 255)
        pointLight.Range = 15
        pointLight.Brightness = 2
        pointLight.Parent = gazePart
        
        workspace.CurrentCamera.CameraSubject = gazePart
        
        GazeActive = true
        GazeBtn.Text = "🎯 Gaze: ON"
        GazeBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
        
        wait(0.1)
        workspace.FallenPartsDestroyHeight = -1000
        
        hrp.CFrame = CFrame.new(targetPos)
        wait(0.05)
        hrp.Anchored = true
        
        gazeConnection = RunService.Heartbeat:Connect(function()
            if GazeActive and player.Character then
                local root = player.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    root.Velocity = Vector3.new(0, 0, 0)
                    root.Anchored = true
                end
            end
        end)
    end
end

